+def _record_owner_fallback(
+    *,
+    accumulator: _Accumulator,
+    index: SelectorIndex,
+    owner: OwnerInfo,
+    changed_path: str,
+    dependency_class: str,
+    witness_id: str,
+    status: WitnessStatus,
+    detail: str,
+) -> None:
+    owner_tests = _owner_tests(index, owner.owner_key)
+    if not owner_tests:
+        return
+    accumulator.add_witness(
+        DependencyWitness(
+            witness_id=witness_id,
+            dependency_class=dependency_class,
+            subject=owner.owner_key,
+            status=status,
+            detail=detail,
+            related_tests=tuple(owner_tests),
+            changed_paths=(changed_path,),
+        )
+    )
+    accumulator.select_tests(
+        stage="fallback",
+        test_paths=owner_tests,
+        reason_kind="owner_fallback_widening",
+        dependency_class=dependency_class,
+        witness_id=witness_id,
+        detail=detail,
+        changed_paths=[changed_path],
+    )
+
+
+
+def _record_reverse_dependency_fallback(
+    *,
+    accumulator: _Accumulator,
+    index: SelectorIndex,
+    owner: OwnerInfo,
+    changed_path: str,
+    dependency_class: str,
+    status: WitnessStatus,
+    detail_prefix: str,
+) -> None:
+    for dependent_owner_key in owner.reverse_local_dependency_owners:
+        dependent_tests = _owner_tests(index, dependent_owner_key)
+        if not dependent_tests:
+            continue
+        witness_id = f"reverse_dep:{owner.owner_key}:{dependent_owner_key}:{changed_path}"
+        detail = f"{detail_prefix}: {dependent_owner_key} depends transitively on {owner.owner_key}"
+        accumulator.add_witness(
+            DependencyWitness(
+                witness_id=witness_id,
+                dependency_class="reverse_local_package_dependency",
+                subject=f"{dependent_owner_key}<-{owner.owner_key}",
+                status=status,
+                detail=detail,
+                related_tests=tuple(dependent_tests),
+                changed_paths=(changed_path,),
+            )
+        )
+        accumulator.select_tests(
+            stage="fallback",
+            test_paths=dependent_tests,
+            reason_kind="reverse_local_package_dependency",
+            dependency_class="reverse_local_package_dependency",
+            witness_id=witness_id,
+            detail=detail,
+            changed_paths=[changed_path],
+        )
+
+
+
+def _record_full_suite_escalation(
+    *,
+    accumulator: _Accumulator,
+    witness_id: str,
+    reason_kind: str,
+    detail: str,
+    changed_paths: Iterable[str],
+) -> None:
+    changed_tuple = tuple(sorted(set(changed_paths)))
+    accumulator.add_witness(
+        DependencyWitness(
+            witness_id=witness_id,
+            dependency_class="escalation_rule",
+            subject="full_python_suite",
+            status="unknown",
+            detail=detail,
+            changed_paths=changed_tuple,
+        )
+    )
+    accumulator.add_escalation(
+        EscalationDecision(
+            reason_kind=reason_kind,
+            dependency_class="escalation_rule",
+            witness_id=witness_id,
+            detail=detail,
+            changed_paths=changed_tuple,
+        )
+    )
+
+
+
+def _process_changed_path(index: SelectorIndex, accumulator: _Accumulator, changed_path: str) -> None:
+    matched_scope = False
+    owner_key = _owner_key_for_path(path=changed_path, owners=index.owners)
+    owner = index.owners.get(owner_key) if owner_key is not None else None
+
+    if changed_path in ROOT_ESCALATION_PATHS:
+        matched_scope = True
+        accumulator.add_witness(
+            DependencyWitness(
+                witness_id=f"root_config:{changed_path}",
+                dependency_class="foundational_repo_config",
+                subject=changed_path,
+                status="changed",
+                detail=f"{changed_path} changes collection or execution posture for the repo",
+                changed_paths=(changed_path,),
+            )
+        )
+        _record_full_suite_escalation(
+            accumulator=accumulator,
+            witness_id=f"escalation:root_config:{changed_path}",
+            reason_kind="root_config_escalation",
+            detail=f"foundational repo config changed: {changed_path}",
+            changed_paths=[changed_path],
+        )
+        return
+
+    if owner is not None and owner.pyproject_path == changed_path:
+        matched_scope = True
+        witness_id = f"owner_pyproject:{owner.owner_key}"
+        detail = f"{owner.owner_key} package metadata changed"
+        accumulator.add_witness(
+            DependencyWitness(
+                witness_id=witness_id,
+                dependency_class="owner_pyproject",
+                subject=changed_path,
+                status="changed",
+                detail=detail,
+                changed_paths=(changed_path,),
+            )
+        )
+        _record_owner_fallback(
+            accumulator=accumulator,
+            index=index,
+            owner=owner,
+            changed_path=changed_path,
+            dependency_class="owner_pyproject",
+            witness_id=witness_id,
+            status="changed",
+            detail=detail,
+        )
+        _record_reverse_dependency_fallback(
+            accumulator=accumulator,
+            index=index,
+            owner=owner,
+            changed_path=changed_path,
+            dependency_class="owner_pyproject",
+            status="changed",
+            detail_prefix="owner metadata changed",
+        )
+        if _is_foundational_owner(owner):
+            _record_full_suite_escalation(
+                accumulator=accumulator,
+                witness_id=f"escalation:foundational_owner_metadata:{owner.owner_key}",
+                reason_kind="foundational_owner_escalation",
+                detail=f"foundational owner metadata changed: {owner.owner_key}",
+                changed_paths=[changed_path],
+            )
+
+    if changed_path in index.tests_by_owner.get(owner_key or "", ()) or re.match(
+        r"^(packages/[^/]+/tests|apps/[^/]+/tests)/test_.*\.py$",
+        changed_path,
+    ):
+        matched_scope = True
+        selected_test = changed_path if changed_path in index.all_test_paths else None
+        accumulator.add_witness(
+            DependencyWitness(
+                witness_id=f"test_file:{changed_path}",
+                dependency_class="changed_test_file",
+                subject=changed_path,
+                status="changed",
+                detail="pytest module changed directly",
+                related_tests=((selected_test,) if selected_test is not None else ()),
+                changed_paths=(changed_path,),
+            )
+        )
+        if selected_test is not None:
+            accumulator.select_tests(
+                stage="evidence",
+                test_paths=[selected_test],
+                reason_kind="changed_test_file",
+                dependency_class="changed_test_file",
+                witness_id=f"test_file:{changed_path}",
+                detail="pytest module changed directly",
+                changed_paths=[changed_path],
+            )
+
+    if owner is not None and owner.tests_root is not None:
+        tests_root_prefix = f"{owner.tests_root}/"
+        if (
+            changed_path.startswith(tests_root_prefix)
+            and changed_path.endswith(".py")
+            and not Path(changed_path).name.startswith("test_")
+        ):
+            matched_scope = True
+            related_tests = _owner_tests(index, owner.owner_key)
+            accumulator.add_witness(
+                DependencyWitness(
+                    witness_id=f"test_support:{changed_path}",
+                    dependency_class="test_support_surface",
+                    subject=changed_path,
+                    status="changed",
+                    detail="test support module changed",
+                    related_tests=tuple(related_tests),
+                    changed_paths=(changed_path,),
+                )
+            )
+            accumulator.select_tests(
+                stage="evidence",
+                test_paths=related_tests,
+                reason_kind="test_support_dependency",
+                dependency_class="test_support_surface",
+                witness_id=f"test_support:{changed_path}",
+                detail="test support module changed",
+                changed_paths=[changed_path],
+            )
+
+    if (
+        owner is not None
+        and owner.src_root is not None
+        and changed_path.startswith(f"{owner.src_root}/")
+        and changed_path.endswith(".py")
+    ):
+        matched_scope = True
+        module_path = _source_module_path_for_file(owner=owner, repo_rel_path=changed_path)
+        if module_path is None:
+            accumulator.add_witness(
+                DependencyWitness(
+                    witness_id=f"source_module:{changed_path}",
+                    dependency_class="source_module",
+                    subject=changed_path,
+                    status="unknown",
+                    detail="could not derive module import path for changed source file",
+                    changed_paths=(changed_path,),
+                )
+            )
+            if _is_foundational_owner(owner):
+                _record_full_suite_escalation(
+                    accumulator=accumulator,
+                    witness_id=f"escalation:unknown_source:{owner.owner_key}:{changed_path}",
+                    reason_kind="unknown_reach_escalation",
+                    detail=f"foundational owner source reach unresolved: {owner.owner_key}",
+                    changed_paths=[changed_path],
+                )
+            else:
+                _record_owner_fallback(
+                    accumulator=accumulator,
+                    index=index,
+                    owner=owner,
+                    changed_path=changed_path,
+                    dependency_class="package_local_blast_radius",
+                    witness_id=f"owner_fallback:{owner.owner_key}:{changed_path}",
+                    status="unknown",
+                    detail="could not derive direct reach for changed source module; widening to owner tests",
+                )
+        else:
+            impacted_modules = _reverse_module_closure(index, [module_path])
+            impacted_tests = set(_tests_importing_any_module(index, impacted_modules))
+            path_tests = set(_tests_referencing_path(index, changed_path))
+            intent_tests = set(index.intent_source_path_to_tests.get(changed_path, set()))
+            evidence_tests = sorted(impacted_tests | path_tests | intent_tests)
+            if changed_path in index.source_parse_errors:
+                status: WitnessStatus = "unknown"
+                detail = (
+                    f"changed source file could not be parsed ({index.source_parse_errors[changed_path]})"
+                )
+            else:
+                status = "changed"
+                detail = f"changed source module {module_path} propagates through recovered imports"
+            accumulator.add_witness(
+                DependencyWitness(
+                    witness_id=f"source_module:{module_path}",
+                    dependency_class="source_module",
+                    subject=changed_path,
+                    status=status,
+                    detail=detail,
+                    related_tests=tuple(sorted(evidence_tests)),
+                    changed_paths=(changed_path,),
+                )
+            )
+            if impacted_tests:
+                accumulator.select_tests(
+                    stage="evidence",
+                    test_paths=sorted(impacted_tests),
+                    reason_kind="direct_import_dependency",
+                    dependency_class="source_module",
+                    witness_id=f"source_module:{module_path}",
+                    detail=detail,
+                    changed_paths=[changed_path],
+                )
+            if path_tests:
+                accumulator.select_tests(
+                    stage="evidence",
+                    test_paths=sorted(path_tests),
+                    reason_kind="artifact_consumer_dependency",
+                    dependency_class="source_module",
+                    witness_id=f"source_module:{module_path}",
+                    detail="tests reference the changed source path explicitly",
+                    changed_paths=[changed_path],
+                )
+            if intent_tests:
+                accumulator.add_witness(
+                    DependencyWitness(
+                        witness_id=f"intent_guard:{changed_path}",
+                        dependency_class="intent_guarded_surface",
+                        subject=changed_path,
+                        status="changed",
+                        detail="repo_test_intent_matrix binds tests to this guarded surface",
+                        related_tests=tuple(sorted(intent_tests)),
+                        changed_paths=(changed_path,),
+                    )
+                )
+                accumulator.select_tests(
+                    stage="evidence",
+                    test_paths=sorted(intent_tests),
+                    reason_kind="guarded_surface_binding",
+                    dependency_class="intent_guarded_surface",
+                    witness_id=f"intent_guard:{changed_path}",
+                    detail="repo_test_intent_matrix binds tests to this guarded surface",
+                    changed_paths=[changed_path],
+                )
+            if not evidence_tests:
+                if _is_foundational_owner(owner):
+                    _record_full_suite_escalation(
+                        accumulator=accumulator,
+                        witness_id=f"escalation:no_evidence_source:{owner.owner_key}:{module_path}",
+                        reason_kind="foundational_owner_escalation",
+                        detail=(
+                            f"foundational owner changed with no recoverable direct test reach: {owner.owner_key}"
+                        ),
+                        changed_paths=[changed_path],
+                    )
+                else:
+                    _record_owner_fallback(
+                        accumulator=accumulator,
+                        index=index,
+                        owner=owner,
+                        changed_path=changed_path,
+                        dependency_class="package_local_blast_radius",
+                        witness_id=f"owner_fallback:{owner.owner_key}:{module_path}",
+                        status="unknown",
+                        detail=(
+                            "no direct dependency evidence was recovered for the changed source module; "
+                            "widening to owner tests"
+                        ),
+                    )
+
+    if (
+        owner is not None
+        and owner.scripts_root is not None
+        and changed_path.startswith(f"{owner.scripts_root}/")
+        and changed_path.endswith(".py")
+    ):
+        matched_scope = True
+        matched_tests = _tests_referencing_path(index, changed_path)
+        if matched_tests:
+            accumulator.add_witness(
+                DependencyWitness(
+                    witness_id=f"script_path:{changed_path}",
+                    dependency_class="app_script_surface",
+                    subject=changed_path,
+                    status="changed",
+                    detail="app script changed and explicit consumers were found",
+                    related_tests=tuple(matched_tests),
+                    changed_paths=(changed_path,),
+                )
+            )
+            accumulator.select_tests(
+                stage="evidence",
+                test_paths=matched_tests,
+                reason_kind="artifact_consumer_dependency",
+                dependency_class="app_script_surface",
+                witness_id=f"script_path:{changed_path}",
+                detail="app script changed and explicit consumers were found",
+                changed_paths=[changed_path],
+            )
+        elif owner is not None:
+            _record_owner_fallback(
+                accumulator=accumulator,
+                index=index,
+                owner=owner,
+                changed_path=changed_path,
+                dependency_class="app_script_surface",
+                witness_id=f"script_path:{changed_path}",
+                status="unknown",
+                detail="app script changed but direct consumer reach could not be narrowed safely",
+            )
+
+    is_artifact_surface = (
+        any(changed_path.startswith(prefix) for prefix in RECOGNIZED_ARTIFACT_ROOT_PREFIXES)
+        or Path(changed_path).suffix in RECOGNIZED_ARTIFACT_EXTENSIONS
+    )
+    if is_artifact_surface and not changed_path.endswith(".py"):
+        matched_scope = True
+        matched_tests = _tests_referencing_path(index, changed_path)
+        if matched_tests:
+            accumulator.add_witness(
+                DependencyWitness(
+                    witness_id=f"artifact_path:{changed_path}",
+                    dependency_class="artifact_or_fixture_surface",
+                    subject=changed_path,
+                    status="changed",
+                    detail="artifact or fixture path changed and explicit consumers were found",
+                    related_tests=tuple(matched_tests),
+                    changed_paths=(changed_path,),
+                )
+            )
+            accumulator.select_tests(
+                stage="evidence",
+                test_paths=matched_tests,
+                reason_kind="artifact_consumer_dependency",
+                dependency_class="artifact_or_fixture_surface",
+                witness_id=f"artifact_path:{changed_path}",
+                detail="artifact or fixture path changed and explicit consumers were found",
+                changed_paths=[changed_path],
+            )
+        else:
+            unknown_tests = _tests_for_unknown_artifact(index, changed_path)
+            accumulator.add_witness(
+                DependencyWitness(
+                    witness_id=f"artifact_path:{changed_path}",
+                    dependency_class="artifact_or_fixture_surface",
+                    subject=changed_path,
+                    status="unknown",
+                    detail=(
+                        "artifact or fixture path changed but explicit consumers were not fully "
+                        "recoverable"
+                    ),
+                    related_tests=tuple(unknown_tests),
+                    changed_paths=(changed_path,),
+                )
+            )
+            accumulator.select_tests(
+                stage="fallback",
+                test_paths=unknown_tests,
+                reason_kind="owner_fallback_widening",
+                dependency_class="artifact_or_fixture_surface",
+                witness_id=f"artifact_path:{changed_path}",
+                detail=(
+                    "artifact or fixture path changed but explicit consumers were not fully "
+                    "recoverable"
+                ),
+                changed_paths=[changed_path],
+            )
+
+    if not matched_scope:
+        accumulator.out_of_scope_changed_paths.append(changed_path)
+
+
+
+def select_python_tests_v0(
+    *,
+    changed_paths: Iterable[str],
+    repo_root: Path | None = None,
+    intent_matrix_path: str | None = DEFAULT_INTENT_MATRIX_PATH,
+) -> dict[str, Any]:
+    index = build_selector_index(repo_root=repo_root, intent_matrix_path=intent_matrix_path)
+    accumulator = _Accumulator()
+    accumulator.warnings.extend(index.warnings)
+
+    normalized_changed_paths = sorted({_normalize_repo_rel_path(path) for path in changed_paths})
+    for changed_path in normalized_changed_paths:
+        _process_changed_path(index, accumulator, changed_path)
+
+    full_suite_recommended = bool(accumulator.escalation_rows)
+    if full_suite_recommended:
+        for decision in sorted(
+            accumulator.escalation_rows.values(),
+            key=lambda row: (row.reason_kind, row.witness_id, row.detail),
+        ):
+            accumulator.select_tests(
+                stage="escalation",
+                test_paths=index.all_test_paths,
+                reason_kind=decision.reason_kind,
+                dependency_class=decision.dependency_class,
+                witness_id=decision.witness_id,
+                detail=decision.detail,
+                changed_paths=decision.changed_paths,
+            )
+        accumulator.add_witness(
+            DependencyWitness(
+                witness_id="escalation:full_suite",
+                dependency_class="escalation_rule",
+                subject="full_python_suite",
+                status="unknown",
+                detail="one or more widening rules require a full local Python test run",
+                related_tests=tuple(index.all_test_paths),
+                changed_paths=tuple(normalized_changed_paths),
+            )
+        )
+
+    evidence_selected_test_paths = sorted(accumulator.evidence_selected)
+    fallback_selected_test_paths = sorted(accumulator.fallback_selected - accumulator.evidence_selected)
+    escalation_selected_test_paths = sorted(
+        accumulator.escalation_selected - accumulator.evidence_selected - accumulator.fallback_selected
+    )
+    selected_test_paths = sorted(
+        accumulator.evidence_selected | accumulator.fallback_selected | accumulator.escalation_selected
+    )
+    skipped_test_paths = sorted(set(index.all_test_paths) - set(selected_test_paths))
+    if full_suite_recommended:
+        risk_posture = "escalated"
+    elif fallback_selected_test_paths or any(
+        witness.status == "unknown" for witness in accumulator.witnesses.values()
+    ):
+        risk_posture = "widened"
+    else:
+        risk_posture = "narrow"
+
+    return {
+        "schema": SCHEMA,
+        "selection_algorithm": SELECTOR_VERSION,
+        "repo_root": index.repo_root.as_posix(),
+        "changed_paths": normalized_changed_paths,
+        "dependency_class_statuses": [
+            witness.to_dict()
+            for witness in sorted(accumulator.witnesses.values(), key=lambda row: row.witness_id)
+        ],
+        "evidence_selected_test_paths": evidence_selected_test_paths,
+        "fallback_selected_test_paths": fallback_selected_test_paths,
+        "escalation_selected_test_paths": escalation_selected_test_paths,
+        "selected_test_paths": selected_test_paths,
+        "skipped_test_paths": skipped_test_paths,
+        "selection_reasons": accumulator.selection_reasons(),
+        "risk_posture": risk_posture,
+        "full_suite_recommended": full_suite_recommended,
+        "escalation_reasons": accumulator.escalation_reasons(),
+        "out_of_scope_changed_paths": sorted(set(accumulator.out_of_scope_changed_paths)),
+        "warnings": sorted(set(accumulator.warnings)),
+        "pytest_args": selected_test_paths,
+        "summary": {
+            "selected_test_count": len(selected_test_paths),
+            "evidence_selected_test_count": len(evidence_selected_test_paths),
+            "fallback_selected_test_count": len(fallback_selected_test_paths),
+            "escalation_selected_test_count": len(escalation_selected_test_paths),
+            "skipped_test_count": len(skipped_test_paths),
+            "unknown_witness_count": sum(
+                1 for witness in accumulator.witnesses.values() if witness.status == "unknown"
+            ),
+            "changed_witness_count": sum(
+                1 for witness in accumulator.witnesses.values() if witness.status == "changed"
+            ),
+            "out_of_scope_changed_path_count": len(set(accumulator.out_of_scope_changed_paths)),
+        },
+    }
+
+
+
+def _parse_args(argv: list[str]) -> argparse.Namespace:
+    parser = argparse.ArgumentParser(
+        description=(
+            "Plan a conservative local Python pytest selection using dependency witnesses, "
+            "owner metadata, import closure, and optional repo_test_intent_matrix bindings."
+        )
+    )
+    parser.add_argument("--repo-root", type=Path, default=None)
+    parser.add_argument("--changed-path", action="append", default=[])
+    parser.add_argument("--changed-paths-file", type=Path, default=None)
+    parser.add_argument("--base-ref", default=None)
+    parser.add_argument("--no-untracked", action="store_true")
+    parser.add_argument("--intent-matrix-path", default=DEFAULT_INTENT_MATRIX_PATH)
+    parser.add_argument("--no-intent-matrix", action="store_true")
+    parser.add_argument("--write-artifact", type=Path, default=None)
+    parser.add_argument(
+        "--stdout-format",
+        choices=("json", "paths", "pytest-args"),
+        default="json",
+    )
+    return parser.parse_args(argv)
+
+
+
+def _read_changed_paths_from_file(path: Path) -> list[str]:
+    return [
+        _normalize_repo_rel_path(line)
+        for line in path.read_text(encoding="utf-8").splitlines()
+        if line.strip()
+    ]
+
+
+
+def main(argv: list[str] | None = None) -> int:
+    namespace = _parse_args(argv or [])
+    changed_paths = list(namespace.changed_path)
+    if namespace.changed_paths_file is not None:
+        changed_paths.extend(_read_changed_paths_from_file(namespace.changed_paths_file))
+    if namespace.base_ref is not None:
+        changed_paths.extend(
+            discover_changed_paths_from_git(
+                repo_root=namespace.repo_root,
+                base_ref=namespace.base_ref,
+                include_untracked=not namespace.no_untracked,
+            )
+        )
+    payload = select_python_tests_v0(
+        changed_paths=changed_paths,
+        repo_root=namespace.repo_root,
+        intent_matrix_path=(None if namespace.no_intent_matrix else namespace.intent_matrix_path),
+    )
+
+    if namespace.write_artifact is not None:
+        namespace.write_artifact.parent.mkdir(parents=True, exist_ok=True)
+        namespace.write_artifact.write_text(
+            json.dumps(payload, indent=2, sort_keys=True) + "\n",
+            encoding="utf-8",
+        )
+
+    if namespace.stdout_format == "json":
+        print(json.dumps(payload, indent=2, sort_keys=True))
+    elif namespace.stdout_format in {"paths", "pytest-args"}:
+        for test_path in payload["selected_test_paths"]:
+            print(test_path)
+    return 0
+
+
+if __name__ == "__main__":  # pragma: no cover
+    raise SystemExit(main())
