    "analysis_request_id",
    "analysis_request_ref",
    "source_set_hash",
    "authority_boundary_policy",
    "interpretation_register",
    "chosen_interpretation_id",
    "escalation_trigger_policy",
    "compile_entitlement"
  ],
  "title": "AdeuArchitectureAnalysisSettlementFrame",
  "type": "object"
