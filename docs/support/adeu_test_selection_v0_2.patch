+@dataclass(frozen=True)
+class DependencyWitness:
+    witness_id: str
+    dependency_class: str
+    subject: str
+    status: WitnessStatus
+    detail: str
+    related_tests: tuple[str, ...] = ()
+    changed_paths: tuple[str, ...] = ()
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "witness_id": self.witness_id,
+            "dependency_class": self.dependency_class,
+            "subject": self.subject,
+            "status": self.status,
+            "detail": self.detail,
+            "related_tests": list(self.related_tests),
+            "changed_paths": list(self.changed_paths),
+        }
+
+
+@dataclass(frozen=True)
+class EscalationDecision:
+    reason_kind: str
+    dependency_class: str
+    witness_id: str
+    detail: str
+    changed_paths: tuple[str, ...] = ()
+
+
+@dataclass
+class _Accumulator:
+    selected_by_stage: dict[SelectionStage, set[str]] = field(
+        default_factory=lambda: {
+            "evidence": set(),
+            "fallback": set(),
+            "escalation": set(),
+        }
+    )
+    reasons_by_test: dict[str, dict[tuple[str, str, str, str, str], SelectionReason]] = field(
+        default_factory=lambda: defaultdict(dict)
+    )
+    witnesses: dict[str, DependencyWitness] = field(default_factory=dict)
+    warnings: list[str] = field(default_factory=list)
+    escalation_rows: dict[tuple[str, str, str, tuple[str, ...]], EscalationDecision] = field(
+        default_factory=dict
+    )
+    out_of_scope_changed_paths: list[str] = field(default_factory=list)
+
+    def add_witness(self, witness: DependencyWitness) -> None:
+        existing = self.witnesses.get(witness.witness_id)
+        if existing is None:
+            self.witnesses[witness.witness_id] = witness
+            return
+        status_order = {"identical": 0, "changed": 1, "unknown": 2}
+        if status_order[witness.status] >= status_order[existing.status]:
+            merged_tests = tuple(sorted(set(existing.related_tests) | set(witness.related_tests)))
+            merged_changed = tuple(sorted(set(existing.changed_paths) | set(witness.changed_paths)))
+            self.witnesses[witness.witness_id] = DependencyWitness(
+                witness_id=witness.witness_id,
+                dependency_class=witness.dependency_class,
+                subject=witness.subject,
+                status=witness.status,
+                detail=witness.detail,
+                related_tests=merged_tests,
+                changed_paths=merged_changed,
+            )
+
+    def select_tests(
+        self,
+        *,
+        stage: SelectionStage,
+        test_paths: Iterable[str],
+        reason_kind: str,
+        dependency_class: str,
+        witness_id: str,
+        detail: str,
+        changed_paths: Iterable[str],
+    ) -> None:
+        normalized_changed_paths = tuple(sorted(set(changed_paths)))
+        for test_path in sorted(set(test_paths)):
+            self.selected_by_stage[stage].add(test_path)
+            reason = SelectionReason(
+                test_path=test_path,
+                selection_stage=stage,
+                reason_kind=reason_kind,
+                dependency_class=dependency_class,
+                witness_id=witness_id,
+                detail=detail,
+                changed_paths=normalized_changed_paths,
+            )
+            key = (
+                reason.selection_stage,
+                reason.reason_kind,
+                reason.dependency_class,
+                reason.witness_id,
+                reason.detail,
+            )
+            self.reasons_by_test[test_path][key] = reason
+
+    def add_escalation(self, decision: EscalationDecision) -> None:
+        key = (
+            decision.reason_kind,
+            decision.dependency_class,
+            decision.witness_id,
+            tuple(sorted(set(decision.changed_paths))),
+        )
+        self.escalation_rows[key] = EscalationDecision(
+            reason_kind=decision.reason_kind,
+            dependency_class=decision.dependency_class,
+            witness_id=decision.witness_id,
+            detail=decision.detail,
+            changed_paths=tuple(sorted(set(decision.changed_paths))),
+        )
+
+    def selection_reasons(self) -> list[dict[str, Any]]:
+        rows: list[dict[str, Any]] = []
+        for test_path in sorted(self.reasons_by_test):
+            for reason in self.reasons_by_test[test_path].values():
+                rows.append(reason.to_dict())
+        return rows
+
+    @property
+    def evidence_selected(self) -> set[str]:
+        return set(self.selected_by_stage["evidence"])
+
+    @property
+    def fallback_selected(self) -> set[str]:
+        return set(self.selected_by_stage["fallback"])
+
+    @property
+    def escalation_selected(self) -> set[str]:
+        return set(self.selected_by_stage["escalation"])
+
+    def escalation_reasons(self) -> list[str]:
+        return sorted({decision.detail for decision in self.escalation_rows.values()})
+
+
+
+def _normalize_repo_rel_path(value: str) -> str:
+    normalized = value.strip().replace("\\", "/")
+    if not normalized:
+        raise ValueError("path must not be empty")
+    if normalized.startswith("/"):
+        raise ValueError(f"path must be repository-relative: {value!r}")
+    pure = PurePosixPath(normalized)
+    if ".." in pure.parts:
+        raise ValueError(f"path must not contain parent traversal: {value!r}")
+    return pure.as_posix()
+
+
+
+def _normalize_dependency_name(raw_dependency: str) -> str:
+    match = re.match(r"^[A-Za-z0-9_.-]+", raw_dependency.strip())
+    if not match:
+        return raw_dependency.strip()
+    return match.group(0)
+
+
+
+def _source_module_path_for_file(*, owner: OwnerInfo, repo_rel_path: str) -> str | None:
+    if owner.src_root is None:
+        return None
+    prefix = f"{owner.src_root}/"
+    if not repo_rel_path.startswith(prefix) or not repo_rel_path.endswith(".py"):
+        return None
+    suffix = repo_rel_path[len(prefix) :]
+    if suffix == "__init__.py":
+        if not owner.import_roots:
+            return None
+        return owner.import_roots[0]
+    if suffix.endswith("/__init__.py"):
+        return suffix[: -len("/__init__.py")].replace("/", ".")
+    return suffix[: -len(".py")].replace("/", ".")
+
+
+
+def _support_module_path_for_file(*, owner: OwnerInfo, repo_rel_path: str) -> str | None:
+    if owner.tests_root is None:
+        return None
+    prefix = f"{owner.tests_root}/"
+    if not repo_rel_path.startswith(prefix) or not repo_rel_path.endswith(".py"):
+        return None
+    suffix = repo_rel_path[len(prefix) :]
+    if Path(repo_rel_path).name.startswith("test_"):
+        return None
+    namespace = ".".join([TEST_SUPPORT_MODULE_ROOT, *owner.owner_key.split("/")])
+    if suffix == "__init__.py":
+        return namespace
+    if suffix.endswith("/__init__.py"):
+        body = suffix[: -len("/__init__.py")].replace("/", ".")
+        return f"{namespace}.{body}" if body else namespace
+    body = suffix[: -len(".py")].replace("/", ".")
+    return f"{namespace}.{body}" if body else namespace
+
+
+
+def _parent_modules(module_path: str) -> list[str]:
+    parts = module_path.split(".")
+    parents: list[str] = []
+    for index in range(1, len(parts)):
+        parents.append(".".join(parts[:index]))
+    return parents
+
+
+
+def _resolve_relative_import(*, current_module: str, module: str | None, level: int) -> str | None:
+    if level == 0:
+        return module or ""
+    current_parts = current_module.split(".")
+    if not current_parts:
+        return None
+    package_parts = current_parts[:-1]
+    ascend = level - 1
+    if ascend > len(package_parts):
+        return None
+    base_parts = package_parts[: len(package_parts) - ascend]
+    if module:
+        base_parts.extend(module.split("."))
+    return ".".join(part for part in base_parts if part)
+
+
+
+def _resolve_special_alias(name: str, *, special_module_aliases: dict[str, str] | None) -> str | None:
+    if not special_module_aliases:
+        return None
+    parts = name.split(".")
+    for size in range(len(parts), 0, -1):
+        candidate = ".".join(parts[:size])
+        mapped = special_module_aliases.get(candidate)
+        if mapped is None:
+            continue
+        if size == len(parts):
+            return mapped
+        suffix = ".".join(parts[size:])
+        return f"{mapped}.{suffix}"
+    return None
+
+
+
+def _best_known_module(
+    name: str,
+    *,
+    known_modules: set[str],
+    known_roots: set[str],
+    special_module_aliases: dict[str, str] | None = None,
+) -> str | None:
+    special_candidate = _resolve_special_alias(name, special_module_aliases=special_module_aliases)
+    if special_candidate is not None and special_candidate in known_modules:
+        return special_candidate
+    if name in known_modules:
+        return name
+    parts = name.split(".")
+    if not parts or parts[0] not in known_roots:
+        return None
+    for size in range(len(parts), 0, -1):
+        candidate = ".".join(parts[:size])
+        if candidate in known_modules:
+            return candidate
+    return parts[0] if parts[0] in known_modules else None
+
+
+
+def _local_module_imports_from_tree(
+    tree: ast.AST,
+    *,
+    current_module: str | None,
+    known_modules: set[str],
+    known_roots: set[str],
+    special_module_aliases: dict[str, str] | None = None,
+) -> set[str]:
+    imported_modules: set[str] = set()
+
+    for node in ast.walk(tree):
+        if isinstance(node, ast.Import):
+            for alias in node.names:
+                candidate = _best_known_module(
+                    alias.name,
+                    known_modules=known_modules,
+                    known_roots=known_roots,
+                    special_module_aliases=special_module_aliases,
+                )
+                if candidate is not None:
+                    imported_modules.add(candidate)
+        elif isinstance(node, ast.ImportFrom):
+            if node.level:
+                if current_module is None:
+                    continue
+                resolved = _resolve_relative_import(
+                    current_module=current_module,
+                    module=node.module,
+                    level=node.level,
+                )
+                if not resolved:
+                    continue
+            else:
+                resolved = node.module or ""
+            if resolved:
+                candidate = _best_known_module(
+                    resolved,
+                    known_modules=known_modules,
+                    known_roots=known_roots,
+                    special_module_aliases=special_module_aliases,
+                )
+                if candidate is not None:
+                    imported_modules.add(candidate)
+            for alias in node.names:
+                if alias.name == "*" or not resolved:
+                    continue
+                submodule_candidate = f"{resolved}.{alias.name}"
+                candidate = _best_known_module(
+                    submodule_candidate,
+                    known_modules=known_modules,
+                    known_roots=known_roots,
+                    special_module_aliases=special_module_aliases,
+                )
+                if candidate is not None:
+                    imported_modules.add(candidate)
+
+    expanded: set[str] = set(imported_modules)
+    for module_path in list(imported_modules):
+        expanded.update(parent for parent in _parent_modules(module_path) if parent in known_modules)
+    return expanded
+
+
+
+def _normalize_path_fragment(value: str) -> str:
+    normalized = value.strip().replace("\\", "/")
+    while "//" in normalized:
+        normalized = normalized.replace("//", "/")
+    return normalized.strip()
+
+
+
+def _is_repo_candidate_path(candidate: str, *, repo_root: Path) -> bool:
+    if not candidate:
+        return False
+    if candidate in ROOT_ESCALATION_PATHS:
+        return True
+    if any(candidate.startswith(prefix) for prefix in RECOGNIZED_REPO_PREFIXES):
+        return (repo_root / candidate.rstrip("/")).exists()
+    return False
+
+
+
+def _resolve_repo_candidate_path(*, candidate: str, repo_root: Path, file_path: Path) -> str | None:
+    normalized = _normalize_path_fragment(candidate)
+    if not normalized:
+        return None
+    if _is_repo_candidate_path(normalized, repo_root=repo_root):
+        return normalized.rstrip("/")
+    try:
+        joined = (file_path.parent / normalized).resolve()
+    except (OSError, RuntimeError, ValueError):
+        return None
+    try:
+        repo_rel = joined.relative_to(repo_root.resolve()).as_posix()
+    except ValueError:
+        return None
+    try:
+        exists = joined.exists()
+    except (OSError, RuntimeError, ValueError):
+        return None
+    if exists and _is_repo_candidate_path(repo_rel, repo_root=repo_root):
+        return repo_rel.rstrip("/")
+    return None
+
+
+
+def _joined_path_suffixes(node: ast.AST) -> set[str]:
+    if isinstance(node, ast.Constant) and isinstance(node.value, str):
+        normalized = _normalize_path_fragment(node.value)
+        return {normalized} if normalized else set()
+    if isinstance(node, ast.BinOp) and isinstance(node.op, ast.Div):
+        left_suffixes = _joined_path_suffixes(node.left)
+        right_suffixes = _joined_path_suffixes(node.right)
+        if not right_suffixes:
+            return set()
+        if not left_suffixes:
+            left_suffixes = {""}
+        joined: set[str] = set()
+        for left in left_suffixes:
+            for right in right_suffixes:
+                if not right:
+                    continue
+                if left:
+                    joined.add(f"{left.rstrip('/')}/{right.lstrip('/')}".rstrip("/"))
+                else:
+                    joined.add(right.rstrip("/"))
+        return joined
+    return set()
+
+
+
+def _literal_repo_paths_from_tree(tree: ast.AST, *, repo_root: Path, file_path: Path) -> set[str]:
+    parent_by_id: dict[int, ast.AST] = {}
+    for parent in ast.walk(tree):
+        for child in ast.iter_child_nodes(parent):
+            parent_by_id[id(child)] = parent
+
+    candidates: set[str] = set()
+    for node in ast.walk(tree):
+        if isinstance(node, ast.Constant) and isinstance(node.value, str):
+            parent = parent_by_id.get(id(node))
+            if isinstance(parent, ast.BinOp) and isinstance(parent.op, ast.Div):
+                continue
+            normalized = _normalize_path_fragment(node.value)
+            resolved = _resolve_repo_candidate_path(
+                candidate=normalized,
+                repo_root=repo_root,
+                file_path=file_path,
+            )
+            if resolved is not None:
+                candidates.add(resolved)
+        elif isinstance(node, ast.BinOp) and isinstance(node.op, ast.Div):
+            parent = parent_by_id.get(id(node))
+            if isinstance(parent, ast.BinOp) and isinstance(parent.op, ast.Div):
+                continue
+            for suffix in _joined_path_suffixes(node):
+                normalized = _normalize_path_fragment(suffix)
+                resolved = _resolve_repo_candidate_path(
+                    candidate=normalized,
+                    repo_root=repo_root,
+                    file_path=file_path,
+                )
+                if resolved is not None:
+                    candidates.add(resolved)
+    return candidates
+
+
+
+def _walk_python_sources(
+    repo_root: Path,
+    owners: dict[str, OwnerInfo],
+) -> tuple[dict[str, str], dict[str, str], dict[str, str]]:
+    module_to_source_path: dict[str, str] = {}
+    source_path_to_module: dict[str, str] = {}
+    module_to_owner: dict[str, str] = {}
+    for owner in owners.values():
+        if owner.src_root is None:
+            continue
+        src_root_path = repo_root / owner.src_root
+        if not src_root_path.is_dir():
+            continue
+        for file_path in sorted(src_root_path.rglob("*.py")):
+            repo_rel_path = file_path.relative_to(repo_root).as_posix()
+            module_path = _source_module_path_for_file(owner=owner, repo_rel_path=repo_rel_path)
+            if module_path is None:
+                continue
+            module_to_source_path[module_path] = repo_rel_path
+            source_path_to_module[repo_rel_path] = module_path
+            module_to_owner[module_path] = owner.owner_key
+    return module_to_source_path, source_path_to_module, module_to_owner
+
+
+
+def _walk_support_modules(
+    repo_root: Path,
+    owners: dict[str, OwnerInfo],
+) -> tuple[
+    dict[str, str],
+    dict[str, str],
+    dict[str, set[str]],
+    dict[str, dict[str, str]],
+    dict[str, str],
+]:
+    support_module_to_path: dict[str, str] = {}
+    support_module_to_owner: dict[str, str] = {}
+    support_module_ids_by_owner: dict[str, set[str]] = defaultdict(set)
+    support_aliases_by_owner: dict[str, dict[str, str]] = defaultdict(dict)
+    conftest_module_by_owner: dict[str, str] = {}
+
+    for owner in owners.values():
+        if owner.tests_root is None:
+            continue
+        tests_root_path = repo_root / owner.tests_root
+        if not tests_root_path.is_dir():
+            continue
+        for file_path in sorted(tests_root_path.rglob("*.py")):
+            repo_rel_path = file_path.relative_to(repo_root).as_posix()
+            if file_path.name.startswith("test_"):
+                continue
+            module_id = _support_module_path_for_file(owner=owner, repo_rel_path=repo_rel_path)
+            if module_id is None:
+                continue
+            relative = file_path.relative_to(tests_root_path).as_posix()
+            if relative == "__init__.py":
+                raw_name = ""
+            elif relative.endswith("/__init__.py"):
+                raw_name = relative[: -len("/__init__.py")].replace("/", ".")
+            else:
+                raw_name = relative[: -len(".py")].replace("/", ".")
+            support_module_to_path[module_id] = repo_rel_path
+            support_module_to_owner[module_id] = owner.owner_key
+            support_module_ids_by_owner[owner.owner_key].add(module_id)
+            if raw_name:
+                support_aliases_by_owner[owner.owner_key][raw_name] = module_id
+            if raw_name == "conftest":
+                conftest_module_by_owner[owner.owner_key] = module_id
+
+    return (
+        support_module_to_path,
+        support_module_to_owner,
+        {owner: set(module_ids) for owner, module_ids in support_module_ids_by_owner.items()},
+        {owner: dict(aliases) for owner, aliases in support_aliases_by_owner.items()},
+        conftest_module_by_owner,
+    )
+
+
+
+def _owner_key_for_path(*, path: str, owners: dict[str, OwnerInfo]) -> str | None:
+    best_match: str | None = None
+    for owner_key in owners:
+        if path == owner_key or path.startswith(f"{owner_key}/"):
+            if best_match is None or len(owner_key) > len(best_match):
+                best_match = owner_key
+    return best_match
+
+
+
+def _parse_python_file(
+    path: Path,
+    *,
+    current_module: str | None,
+    known_modules: set[str],
+    known_roots: set[str],
+    repo_root: Path,
+    special_module_aliases: dict[str, str] | None = None,
+) -> tuple[set[str], set[str], str | None]:
+    try:
+        tree = ast.parse(path.read_text(encoding="utf-8"), filename=path.as_posix())
+    except SyntaxError as exc:
+        return set(), set(), f"{type(exc).__name__}: {exc.msg}"
+
+    imported_modules = _local_module_imports_from_tree(
+        tree,
+        current_module=current_module,
+        known_modules=known_modules,
+        known_roots=known_roots,
+        special_module_aliases=special_module_aliases,
+    )
+    literal_paths = _literal_repo_paths_from_tree(tree, repo_root=repo_root, file_path=path)
+    return imported_modules, literal_paths, None
+
+
+
+def _discover_owners(repo_root: Path) -> dict[str, OwnerInfo]:
+    pyproject_paths = sorted(repo_root.glob("packages/*/pyproject.toml")) + sorted(
+        repo_root.glob("apps/*/pyproject.toml")
+    )
+    raw_owners: dict[str, dict[str, Any]] = {}
+    distribution_to_owner: dict[str, str] = {}
+
+    for pyproject_path in pyproject_paths:
+        payload = tomllib.loads(pyproject_path.read_text(encoding="utf-8"))
+        project = payload.get("project", {})
+        owner_root = pyproject_path.parent
+        owner_key = owner_root.relative_to(repo_root).as_posix()
+        owner_kind: Literal["package", "app"] = "package" if owner_key.startswith("packages/") else "app"
+        src_root_path = owner_root / "src"
+        import_roots: list[str] = []
+        if src_root_path.is_dir():
+            for child in sorted(src_root_path.iterdir()):
+                if child.is_dir() and (child / "__init__.py").is_file():
+                    import_roots.append(child.name)
+        scripts_root = owner_root / "scripts"
+        direct_deps = [
+            _normalize_dependency_name(dependency)
+            for dependency in project.get("dependencies", [])
+            if isinstance(dependency, str)
+        ]
+        raw_owners[owner_key] = {
+            "owner_kind": owner_kind,
+            "distribution_name": project.get("name"),
+            "import_roots": tuple(import_roots),
+            "src_root": (src_root_path.relative_to(repo_root).as_posix() if src_root_path.is_dir() else None),
+            "tests_root": (
+                (owner_root / "tests").relative_to(repo_root).as_posix()
+                if (owner_root / "tests").is_dir()
+                else None
+            ),
+            "pyproject_path": pyproject_path.relative_to(repo_root).as_posix(),
+            "scripts_root": (
+                scripts_root.relative_to(repo_root).as_posix() if scripts_root.is_dir() else None
+            ),
+            "direct_deps": tuple(direct_deps),
+        }
+        distribution_name = project.get("name")
+        if isinstance(distribution_name, str) and distribution_name:
+            distribution_to_owner[distribution_name] = owner_key
+
+    reverse_dependencies: dict[str, set[str]] = defaultdict(set)
+    direct_local_dependencies: dict[str, set[str]] = defaultdict(set)
+    for owner_key, metadata in raw_owners.items():
+        for dependency_name in metadata["direct_deps"]:
+            dependency_owner = distribution_to_owner.get(dependency_name)
+            if dependency_owner is None:
+                continue
+            direct_local_dependencies[owner_key].add(dependency_owner)
+            reverse_dependencies[dependency_owner].add(owner_key)
+
+    def reverse_closure(start_owner: str) -> set[str]:
+        seen: set[str] = set()
+        stack = list(reverse_dependencies.get(start_owner, ()))
+        while stack:
+            owner_key = stack.pop()
+            if owner_key in seen:
+                continue
+            seen.add(owner_key)
+            stack.extend(reverse_dependencies.get(owner_key, ()))
+        return seen
+
+    owners: dict[str, OwnerInfo] = {}
+    for owner_key, metadata in raw_owners.items():
+        owners[owner_key] = OwnerInfo(
+            owner_key=owner_key,
+            owner_kind=metadata["owner_kind"],
+            distribution_name=metadata["distribution_name"],
+            import_roots=tuple(sorted(metadata["import_roots"])),
+            src_root=metadata["src_root"],
+            tests_root=metadata["tests_root"],
+            pyproject_path=metadata["pyproject_path"],
+            scripts_root=metadata["scripts_root"],
+            direct_local_dependency_owners=tuple(sorted(direct_local_dependencies.get(owner_key, set()))),
+            reverse_local_dependency_owners=tuple(sorted(reverse_closure(owner_key))),
+        )
+    return owners
+
+
+
+def _transitive_support_literal_paths(
+    *,
+    support_module_id: str,
+    support_imported_modules: dict[str, set[str]],
+    support_literal_paths: dict[str, set[str]],
+    cache: dict[str, set[str]],
+) -> set[str]:
+    cached = cache.get(support_module_id)
+    if cached is not None:
+        return cached
+    merged = set(support_literal_paths.get(support_module_id, set()))
+    for imported_module in support_imported_modules.get(support_module_id, set()):
+        if not imported_module.startswith(f"{TEST_SUPPORT_MODULE_ROOT}."):
+            continue
+        merged.update(
+            _transitive_support_literal_paths(
+                support_module_id=imported_module,
+                support_imported_modules=support_imported_modules,
+                support_literal_paths=support_literal_paths,
+                cache=cache,
+            )
+        )
+    cache[support_module_id] = merged
+    return merged
+
+
+
+def build_selector_index(
+    *,
+    repo_root: Path | None = None,
+    intent_matrix_path: str | None = DEFAULT_INTENT_MATRIX_PATH,
+) -> SelectorIndex:
+    resolved_repo_root = canonical_repo_root(anchor=repo_root or Path.cwd())
+    owners = _discover_owners(resolved_repo_root)
+    module_to_source_path, source_path_to_module, module_to_owner = _walk_python_sources(
+        resolved_repo_root,
+        owners,
+    )
+    (
+        support_module_to_path,
+        support_module_to_owner,
+        support_module_ids_by_owner,
+        support_aliases_by_owner,
+        conftest_module_by_owner,
+    ) = _walk_support_modules(resolved_repo_root, owners)
+
+    source_modules = set(module_to_source_path)
+    support_modules = set(support_module_to_path)
+    known_modules_for_tests = source_modules | support_modules
+    known_roots_for_tests = {module.split(".", 1)[0] for module in known_modules_for_tests}
+    known_roots_for_sources = {module.split(".", 1)[0] for module in source_modules}
+
+    reverse_module_imports: dict[str, set[str]] = defaultdict(set)
+    source_parse_errors: dict[str, str] = {}
+    for module_path, source_path in module_to_source_path.items():
+        imported_modules, _, parse_error = _parse_python_file(
+            resolved_repo_root / source_path,
+            current_module=module_path,
+            known_modules=source_modules,
+            known_roots=known_roots_for_sources,
+            repo_root=resolved_repo_root,
+        )
+        if parse_error is not None:
+            source_parse_errors[source_path] = parse_error
+        for imported_module in imported_modules:
+            if imported_module == module_path:
+                continue
+            reverse_module_imports[imported_module].add(module_path)
+        for parent_module in _parent_modules(module_path):
+            if parent_module in source_modules and parent_module != module_path:
+                reverse_module_imports[parent_module].add(module_path)
+
+    support_imported_modules: dict[str, set[str]] = {}
+    support_literal_paths: dict[str, set[str]] = {}
+    support_parse_errors: dict[str, str] = {}
+    for support_module_id, support_path in support_module_to_path.items():
+        owner_key = support_module_to_owner[support_module_id]
+        imported_modules, literal_paths, parse_error = _parse_python_file(
+            resolved_repo_root / support_path,
+            current_module=support_module_id,
+            known_modules=known_modules_for_tests,
+            known_roots=known_roots_for_tests,
+            repo_root=resolved_repo_root,
+            special_module_aliases=support_aliases_by_owner.get(owner_key),
+        )
+        support_imported_modules[support_module_id] = imported_modules
+        support_literal_paths[support_module_id] = literal_paths
+        if parse_error is not None:
+            support_parse_errors[support_path] = parse_error
+        for imported_module in imported_modules:
+            if imported_module == support_module_id:
+                continue
+            reverse_module_imports[imported_module].add(support_module_id)
+
+    support_literal_cache: dict[str, set[str]] = {}
+    for support_module_id in support_module_to_path:
+        _transitive_support_literal_paths(
+            support_module_id=support_module_id,
+            support_imported_modules=support_imported_modules,
+            support_literal_paths=support_literal_paths,
+            cache=support_literal_cache,
+        )
+
+    tests_by_owner: dict[str, list[str]] = defaultdict(list)
+    all_test_paths: list[str] = []
+    test_imported_modules: dict[str, set[str]] = {}
+    test_literal_paths: dict[str, set[str]] = {}
+    test_parse_errors: dict[str, str] = {}
+    for owner in owners.values():
+        if owner.tests_root is None:
+            continue
+        tests_root_path = resolved_repo_root / owner.tests_root
+        if not tests_root_path.is_dir():
+            continue
+        owner_support_aliases = support_aliases_by_owner.get(owner.owner_key)
+        implicit_conftest = conftest_module_by_owner.get(owner.owner_key)
+        for test_file in sorted(tests_root_path.rglob("test_*.py")):
+            repo_rel_path = test_file.relative_to(resolved_repo_root).as_posix()
+            all_test_paths.append(repo_rel_path)
+            tests_by_owner[owner.owner_key].append(repo_rel_path)
+            imported_modules, literal_paths, parse_error = _parse_python_file(
+                test_file,
+                current_module=None,
+                known_modules=known_modules_for_tests,
+                known_roots=known_roots_for_tests,
+                repo_root=resolved_repo_root,
+                special_module_aliases=owner_support_aliases,
+            )
+            if implicit_conftest is not None:
+                imported_modules.add(implicit_conftest)
+            support_literals: set[str] = set()
+            for imported_module in list(imported_modules):
+                if imported_module.startswith(f"{TEST_SUPPORT_MODULE_ROOT}."):
+                    support_literals.update(support_literal_cache.get(imported_module, set()))
+            literal_paths.update(support_literals)
+            test_imported_modules[repo_rel_path] = imported_modules
+            test_literal_paths[repo_rel_path] = literal_paths
+            if parse_error is not None:
+                test_parse_errors[repo_rel_path] = parse_error
+
+    intent_source_path_to_tests: dict[str, set[str]] = defaultdict(set)
+    warnings: list[str] = []
+    if intent_matrix_path is not None:
+        candidate_path = resolved_repo_root / intent_matrix_path
+        if candidate_path.is_file():
+            try:
+                payload = json.loads(candidate_path.read_text(encoding="utf-8"))
+                for entry in payload.get("test_intent_entries", []):
+                    if not isinstance(entry, dict):
+                        continue
+                    test_ref = entry.get("test_ref")
+                    guarded_surface_ref = entry.get("guarded_surface_ref")
+                    if not isinstance(test_ref, str) or not isinstance(guarded_surface_ref, dict):
+                        continue
+                    if not test_ref.startswith("test:"):
+                        continue
+                    test_path = test_ref.split(":", 1)[1].split("#", 1)[0]
+                    guard_kind = guarded_surface_ref.get("guarded_surface_ref_kind")
+                    guard_value = guarded_surface_ref.get("guarded_surface_ref_value")
+                    if not isinstance(guard_kind, str) or not isinstance(guard_value, str):
+                        continue
+                    source_path: str | None = None
+                    if guard_kind == "internal_module_boundary" and guard_value.startswith("module:"):
+                        source_path = guard_value.split(":", 1)[1]
+                    elif guard_kind == "internal_symbol" and guard_value.startswith("symbol:"):
+                        parts = guard_value.split(":")
+                        if len(parts) >= 4:
+                            source_path = ":".join(parts[1:-2])
+                    if source_path is not None:
+                        intent_source_path_to_tests[_normalize_repo_rel_path(source_path)].add(
+                            _normalize_repo_rel_path(test_path)
+                        )
+            except (json.JSONDecodeError, ValueError) as exc:
+                warnings.append(
+                    f"intent matrix ignored due to parse failure at {intent_matrix_path}: {exc}"
+                )
+        else:
+            warnings.append(f"intent matrix path not found: {intent_matrix_path}")
+
+    warnings.extend(
+        f"support module parse error ignored at {path}: {message}"
+        for path, message in sorted(support_parse_errors.items())
+    )
+
+    return SelectorIndex(
+        repo_root=resolved_repo_root,
+        owners=owners,
+        all_test_paths=sorted(all_test_paths),
+        tests_by_owner={owner_key: sorted(paths) for owner_key, paths in tests_by_owner.items()},
+        module_to_source_path=module_to_source_path,
+        source_path_to_module=source_path_to_module,
+        module_to_owner=module_to_owner,
+        reverse_module_imports={key: set(value) for key, value in reverse_module_imports.items()},
+        test_imported_modules=test_imported_modules,
+        test_literal_paths=test_literal_paths,
+        test_parse_errors=test_parse_errors,
+        source_parse_errors=source_parse_errors,
+        support_module_ids_by_owner={key: set(value) for key, value in support_module_ids_by_owner.items()},
+        support_module_to_owner=support_module_to_owner,
+        conftest_module_by_owner=conftest_module_by_owner,
+        intent_source_path_to_tests={key: set(value) for key, value in intent_source_path_to_tests.items()},
+        warnings=warnings,
+    )
+
+
+
+def discover_changed_paths_from_git(
+    *,
+    repo_root: Path | None = None,
+    base_ref: str | None = None,
+    include_untracked: bool = True,
+) -> list[str]:
+    resolved_repo_root = canonical_repo_root(anchor=repo_root or Path.cwd())
+
+    def _run_git(*args: str) -> list[str]:
+        completed = subprocess.run(
+            ["git", *args],
+            cwd=resolved_repo_root,
+            check=True,
+            capture_output=True,
+            text=True,
+        )
+        return [
+            _normalize_repo_rel_path(line)
+            for line in completed.stdout.splitlines()
+            if line.strip()
+        ]
+
+    changed_paths: set[str] = set()
+    if base_ref is not None:
+        merge_base_completed = subprocess.run(
+            ["git", "merge-base", base_ref, "HEAD"],
+            cwd=resolved_repo_root,
+            check=True,
+            capture_output=True,
+            text=True,
+        )
+        merge_base = merge_base_completed.stdout.strip()
+        if not merge_base:
+            raise RuntimeError(f"git merge-base returned empty output for {base_ref!r}")
+        changed_paths.update(
+            _run_git("diff", "--name-only", "--diff-filter=ACMRD", f"{merge_base}..HEAD")
+        )
+    changed_paths.update(_run_git("diff", "--name-only", "--diff-filter=ACMRD", "HEAD"))
+    if include_untracked:
+        changed_paths.update(_run_git("ls-files", "--others", "--exclude-standard"))
+    return sorted(changed_paths)
+
+
+
+def _reverse_module_closure(index: SelectorIndex, starting_modules: Iterable[str]) -> set[str]:
+    seen: set[str] = set()
+    stack = list(starting_modules)
+    while stack:
+        module_path = stack.pop()
+        if module_path in seen:
+            continue
+        seen.add(module_path)
+        stack.extend(sorted(index.reverse_module_imports.get(module_path, ())))
+    return seen
+
+
+
+def _tests_importing_any_module(index: SelectorIndex, modules: set[str]) -> list[str]:
+    matched: list[str] = []
+    for test_path, imported_modules in index.test_imported_modules.items():
+        if imported_modules & modules:
+            matched.append(test_path)
+    return sorted(matched)
+
+
+
+def _tests_referencing_path(index: SelectorIndex, changed_path: str) -> list[str]:
+    changed_norm = changed_path.rstrip("/")
+    matched: list[str] = []
+    for test_path, literal_paths in index.test_literal_paths.items():
+        for literal_path in literal_paths:
+            literal_norm = literal_path.rstrip("/")
+            if (
+                literal_norm == changed_norm
+                or changed_norm.startswith(f"{literal_norm}/")
+                or literal_norm.startswith(f"{changed_norm}/")
+            ):
+                matched.append(test_path)
+                break
+    return sorted(set(matched))
+
+
+
+def _owner_tests(index: SelectorIndex, owner_key: str | None) -> list[str]:
+    if owner_key is None:
+        return []
+    return list(index.tests_by_owner.get(owner_key, ()))
+
+
+
+def _is_foundational_owner(owner: OwnerInfo) -> bool:
+    return len(owner.reverse_local_dependency_owners) >= FOUNDATIONAL_REVERSE_DEPENDENCY_THRESHOLD
+
