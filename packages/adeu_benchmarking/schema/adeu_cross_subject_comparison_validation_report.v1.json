      "title": "Schema",
      "type": "string"
    },
    "validation_results": {
      "items": {
        "$ref": "#/$defs/CrossSubjectComparisonValidationResult"
      },
      "minItems": 1,
      "title": "Validation Results",
      "type": "array"
    },
    "validation_status": {
      "enum": [
        "validation_ready_clean",
        "validation_insufficient",
        "validation_incompatible"
      ],
      "title": "Validation Status",
      "type": "string"
    }
  },
  "required": [
    "cross_subject_comparison_validation_report_id",
    "comparison_case_ref",
    "deterministic_comparison_confirmed",
    "validation_status",
    "validation_results",
