+class HistoryLedger(BaseModel):
+    model_config = MODEL_CONFIG
+
+    schema_id: Literal[ADEU_HISTORY_LEDGER_SCHEMA] = Field(
+        default=ADEU_HISTORY_LEDGER_SCHEMA,
+        alias="schema",
+    )
+    ledger_id: str
+    source_id: str
+    entries: list[HistoryLedgerEntry] = Field(min_length=1)
+    entry_count: int
+
+    @property
+    def schema(self) -> str:
+        return self.schema_id
+
+    @model_validator(mode="after")
+    def _validate(self) -> "HistoryLedger":
+        for field_name in ("ledger_id", "source_id"):
+            object.__setattr__(
+                self,
+                field_name,
+                _assert_present_text(getattr(self, field_name), field_name=field_name),
+            )
+        object.__setattr__(
+            self,
+            "entry_count",
+            _assert_positive_int(self.entry_count, field_name="entry_count"),
+        )
+        if self.entry_count != len(self.entries):
+            raise ValueError("entry_count must equal len(entries)")
+        entry_ids = [entry.entry_id for entry in self.entries]
+        if entry_ids != _ordered_unique_texts(entry_ids, field_name="entries"):
+            raise ValueError("entries must be unique and ordered")
+        order_indexes = [entry.order_index for entry in self.entries]
+        if order_indexes != sorted(order_indexes):
+            raise ValueError("entries must be sorted by order_index")
+        if any(entry.source_id != self.source_id for entry in self.entries):
+            raise ValueError("entries must all share the ledger source_id")
+        expected_ledger_id = compute_history_ledger_id(
+            source_id=self.source_id,
+            entry_ids=entry_ids,
+        )
+        if self.ledger_id != expected_ledger_id:
+            raise ValueError("ledger_id must derive from source_id and ordered entry_ids")
+        return self
+
