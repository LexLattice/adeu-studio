          "type": "string"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "target_kind": {
          "title": "Target Kind",
          "type": "string"
        },
        "target_ref": {
          "title": "Target Ref",
          "type": "string"
        },
        "typing_id": {
          "title": "Typing Id",
          "type": "string"
        }
      },
      "required": [
        "typing_id",
        "target_ref",
        "target_kind",
        "deontic_class",
        "rationale"
      ],
      "title": "DeonticTypingEntry",
      "type": "object"
