            "schema_export",
            "fixture",
            "tool_run",
            "closeout_artifact"
          ],
          "title": "Evidence Kind",
          "type": "string"
        },
        "evidence_ref": {
          "title": "Evidence Ref",
          "type": "string"
        },
        "limitation_note": {
          "title": "Limitation Note",
          "type": "string"
        },
        "source_refs": {
          "items": {
            "type": "string"
