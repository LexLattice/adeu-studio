{
  "$defs": {
    "RepoDescriptionEvidenceRef": {
      "additionalProperties": false,
      "properties": {
        "evidence_kind": {
          "enum": [
            "observed_anchor_tuple_evidence",
            "structural_signature_evidence",
            "semantic_function_cue_evidence",
            "governance_cue_evidence",
            "lexical_cue_evidence",
            "adjudication_artifact_evidence",
            "reconstruction_subset_evidence",
            "planning_table_row_evidence",
            "planning_selection_evidence",
            "lock_contract_evidence",
            "dependency_policy_evidence"
          ],
          "title": "Evidence Kind",
          "type": "string"
        },
        "evidence_ref": {
          "title": "Evidence Ref",
          "type": "string"
        }
      },
      "required": [
        "evidence_ref",
        "evidence_kind"
      ],
      "title": "RepoDescriptionEvidenceRef",
      "type": "object"
    },
    "RepoDescriptiveNormativeBindingEntry": {
      "additionalProperties": false,
      "properties": {
        "allowed_use_summary": {
          "title": "Allowed Use Summary",
          "type": "string"
        },
        "authority_source_kind": {
          "enum": [
            "descriptive_artifact_only_forbidden",
            "separate_lock_required",
            "separate_decision_required",
            "separate_normative_artifact_required"
          ],
          "title": "Authority Source Kind",
          "type": "string"
        },
        "binding_posture": {
          "enum": [
            "advisory_only",
            "eligibility_signal_only",
            "adjudication_required",
            "separate_normative_authority_required"
          ],
          "title": "Binding Posture",
          "type": "string"
        },
        "consumer_class": {
          "enum": [
            "planning_consumer",
            "adjudication_consumer",
            "policy_consumer",
            "recursive_governance_consumer"
          ],
          "title": "Consumer Class",
          "type": "string"
        },
        "derivation_method": {
          "enum": [
            "descriptive_projection",
            "cross_artifact_join",
            "policy_binding_rule",
            "adjudicated_policy"
          ],
          "title": "Derivation Method",
          "type": "string"
        },
        "derivation_posture": {
          "enum": [
            "observed",
            "derived_deterministically",
            "inferred_heuristically",
            "adjudicated",
            "settled"
          ],
          "title": "Derivation Posture",
          "type": "string"
        },
        "descriptive_input_kind": {
          "enum": [
            "repo_entity_catalog",
            "repo_schema_family_registry",
            "repo_symbol_catalog",
            "repo_dependency_graph",
            "repo_test_intent_matrix",
            "repo_optimization_register"
          ],
          "title": "Descriptive Input Kind",
          "type": "string"
        },
        "descriptive_input_ref": {
          "title": "Descriptive Input Ref",
          "type": "string"
        },
        "entry_id": {
          "title": "Entry Id",
          "type": "string"
        },
        "forbidden_use_summary": {
          "title": "Forbidden Use Summary",
          "type": "string"
        },
        "promotion_law_posture": {
          "enum": [
            "inferred_not_sufficient",
            "adjudication_required_before_normative_use",
            "settled_authority_required_before_execution"
          ],
          "title": "Promotion Law Posture",
          "type": "string"
        },
        "source_artifact_refs": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Source Artifact Refs",
          "type": "array"
        },
        "supporting_evidence_refs": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Supporting Evidence Refs",
          "type": "array"
        }
      },
      "required": [
        "entry_id",
        "descriptive_input_kind",
        "descriptive_input_ref",
        "consumer_class",
        "binding_posture",
        "authority_source_kind",
        "promotion_law_posture",
        "allowed_use_summary",
        "forbidden_use_summary",
        "derivation_posture",
        "derivation_method",
        "source_artifact_refs",
        "supporting_evidence_refs"
      ],
      "title": "RepoDescriptiveNormativeBindingEntry",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "binding_entries": {
      "items": {
        "$ref": "#/$defs/RepoDescriptiveNormativeBindingEntry"
      },
      "minItems": 1,
      "title": "Binding Entries",
      "type": "array"
    },
    "binding_scope": {
      "title": "Binding Scope",
      "type": "string"
    },
    "bound_arc_dependency_register_ref": {
      "title": "Bound Arc Dependency Register Ref",
      "type": "string"
    },
    "bound_dependency_graph_ref": {
      "title": "Bound Dependency Graph Ref",
      "type": "string"
    },
    "bound_entity_catalog_ref": {
      "title": "Bound Entity Catalog Ref",
      "type": "string"
    },
    "bound_optimization_register_ref": {
      "title": "Bound Optimization Register Ref",
      "type": "string"
    },
    "bound_schema_family_registry_ref": {
      "title": "Bound Schema Family Registry Ref",
      "type": "string"
    },
    "bound_symbol_catalog_ref": {
      "title": "Bound Symbol Catalog Ref",
      "type": "string"
    },
    "bound_test_intent_matrix_ref": {
      "title": "Bound Test Intent Matrix Ref",
      "type": "string"
    },
    "evidence_refs": {
      "items": {
        "$ref": "#/$defs/RepoDescriptionEvidenceRef"
      },
      "minItems": 1,
      "title": "Evidence Refs",
      "type": "array"
    },
    "extraction_method": {
      "enum": [
        "descriptive_projection",
        "cross_artifact_join",
        "policy_binding_rule",
        "adjudicated_policy"
      ],
      "title": "Extraction Method",
      "type": "string"
    },
    "extraction_posture": {
      "enum": [
        "observed",
        "derived_deterministically",
        "inferred_heuristically",
        "adjudicated",
        "settled"
      ],
      "title": "Extraction Posture",
      "type": "string"
    },
    "repo_descriptive_normative_binding_frame_id": {
      "title": "Repo Descriptive Normative Binding Frame Id",
      "type": "string"
    },
    "repo_snapshot_hash": {
      "title": "Repo Snapshot Hash",
      "type": "string"
    },
    "repo_snapshot_id": {
      "title": "Repo Snapshot Id",
      "type": "string"
    },
    "schema": {
      "const": "repo_descriptive_normative_binding_frame@1",
      "default": "repo_descriptive_normative_binding_frame@1",
      "title": "Schema",
      "type": "string"
    },
    "snapshot_validity_posture": {
      "enum": [
        "snapshot_bound_current",
        "snapshot_bound_historical"
      ],
      "title": "Snapshot Validity Posture",
      "type": "string"
    },
    "source_set": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Source Set",
      "type": "array"
    },
    "source_set_hash": {
      "title": "Source Set Hash",
      "type": "string"
    }
  },
  "required": [
    "repo_descriptive_normative_binding_frame_id",
    "repo_snapshot_id",
    "repo_snapshot_hash",
    "snapshot_validity_posture",
    "source_set",
    "source_set_hash",
    "bound_entity_catalog_ref",
    "bound_schema_family_registry_ref",
    "bound_symbol_catalog_ref",
    "bound_dependency_graph_ref",
    "bound_arc_dependency_register_ref",
    "bound_test_intent_matrix_ref",
    "bound_optimization_register_ref",
    "binding_scope",
    "extraction_posture",
    "extraction_method",
    "binding_entries",
    "evidence_refs"
  ],
  "title": "RepoDescriptiveNormativeBindingFrame",
  "type": "object"
}
