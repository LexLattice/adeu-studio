{
  "schema": "parallel_arc_implementation_stage_report@2",
  "description": "Machine-checkable stage-end self-report for the parallel-family implementation cycle.",
  "required_fields": [
    "report_id",
    "stage_name",
    "arc_family",
    "slice",
    "arc_branch",
    "feature_branch",
    "worktree_path",
    "status",
    "controlling_refs",
    "contract_items",
    "declared_non_goals",
    "semantic_ir_conformance",
    "mapping_changes",
    "extra_surface_refs",
    "unmapped_surface_refs",
    "artifacts_produced",
    "blockers"
  ],
  "field_contract": {
    "report_id": {
      "type": "string"
    },
    "stage_name": {
      "type": "string",
      "allowed": [
        "semantic_ir_bridge",
        "code_transposition",
        "verification_attestation"
      ]
    },
    "arc_family": {
      "type": "string"
    },
    "slice": {
      "type": "string"
    },
    "arc_branch": {
      "type": "string"
    },
    "feature_branch": {
      "type": "string"
    },
    "worktree_path": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "allowed": [
        "completed",
        "blocked"
      ]
    },
    "controlling_refs": {
      "type": "array"
    },
    "contract_items": {
      "type": "array",
      "entry_contract": {
        "required_fields": [
          "contract_item",
          "status",
          "code_surface_refs",
          "planned_check_refs",
          "deferred_or_non_goal",
          "evidence_ref"
        ],
        "field_contract": {
          "contract_item": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "allowed": [
              "planned",
              "implemented",
              "verified",
              "deferred",
              "blocked"
            ]
          },
          "code_surface_refs": {
            "type": "array"
          },
          "planned_check_refs": {
            "type": "array"
          },
          "deferred_or_non_goal": {
            "type": "boolean"
          },
          "evidence_ref": {
            "type": "string"
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "declared_non_goals": {
      "type": "array"
    },
    "artifacts_produced": {
      "type": "array"
    },
    "checks_run": {
      "type": [
        "array",
        "null"
      ]
    },
    "checks_skipped": {
      "type": [
        "array",
        "null"
      ]
    },
    "blockers": {
      "type": "array"
    },
    "semantic_ir_conformance": {
      "type": [
        "string",
        "null"
      ],
      "allowed": [
        "not_applicable_yet",
        "conformant",
        "changed_with_reason",
        "non_conformant",
        null
      ]
    },
    "mapping_changes": {
      "type": [
        "array",
        "null"
      ],
      "entry_contract": {
        "required_fields": [
          "contract_item",
          "change_summary",
          "reason"
        ],
        "field_contract": {
          "contract_item": {
            "type": "string"
          },
          "change_summary": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "extra_surface_refs": {
      "type": [
        "array",
        "null"
      ]
    },
    "unmapped_surface_refs": {
      "type": [
        "array",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
