{
  "$defs": {
    "ProceduralDepthBenchmarkValidationCaseResult": {
      "additionalProperties": false,
      "properties": {
        "deterministic_replay_confirmed": {
          "title": "Deterministic Replay Confirmed",
          "type": "boolean"
        },
        "expected_dominant_failure_family": {
          "enum": [
            "clean_success",
            "horizontal_plan_spine",
            "vertical_active_step_compilation",
            "reintegration",
            "mixed"
          ],
          "title": "Expected Dominant Failure Family",
          "type": "string"
        },
        "expected_terminal_trace_status": {
          "enum": [
            "completed_clean",
            "completed_with_structural_break"
          ],
          "title": "Expected Terminal Trace Status",
          "type": "string"
        },
        "observed_dominant_failure_family": {
          "enum": [
            "clean_success",
            "horizontal_plan_spine",
            "vertical_active_step_compilation",
            "reintegration",
            "mixed"
          ],
          "title": "Observed Dominant Failure Family",
          "type": "string"
        },
        "observed_terminal_trace_status": {
          "enum": [
            "completed_clean",
            "completed_with_structural_break"
          ],
          "title": "Observed Terminal Trace Status",
          "type": "string"
        },
        "perturbation_case_ref": {
          "title": "Perturbation Case Ref",
          "type": "string"
        },
        "replay_results": {
          "items": {
            "$ref": "#/$defs/ProceduralDepthValidationReplayResult"
          },
          "minItems": 1,
          "title": "Replay Results",
          "type": "array"
        }
      },
      "required": [
        "perturbation_case_ref",
        "expected_dominant_failure_family",
        "observed_dominant_failure_family",
        "expected_terminal_trace_status",
        "observed_terminal_trace_status",
        "deterministic_replay_confirmed",
        "replay_results"
      ],
      "title": "ProceduralDepthBenchmarkValidationCaseResult",
      "type": "object"
    },
    "ProceduralDepthValidationReplayResult": {
      "additionalProperties": false,
      "properties": {
        "diagnostic_report_ref": {
          "title": "Diagnostic Report Ref",
          "type": "string"
        },
        "metric_ref": {
          "title": "Metric Ref",
          "type": "string"
        },
        "replay_index": {
          "minimum": 0,
          "title": "Replay Index",
          "type": "integer"
        },
        "run_trace_ref": {
          "title": "Run Trace Ref",
          "type": "string"
        }
      },
      "required": [
        "replay_index",
        "run_trace_ref",
        "metric_ref",
        "diagnostic_report_ref"
      ],
      "title": "ProceduralDepthValidationReplayResult",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "deterministic_replay_confirmed": {
      "title": "Deterministic Replay Confirmed",
      "type": "boolean"
    },
    "evaluation_context_posture": {
      "const": "deterministic_fixed_context",
      "title": "Evaluation Context Posture",
      "type": "string"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Limitations",
      "type": "array"
    },
    "procedural_depth_benchmark_validation_report_id": {
      "title": "Procedural Depth Benchmark Validation Report Id",
      "type": "string"
    },
    "replay_count": {
      "minimum": 1,
      "title": "Replay Count",
      "type": "integer"
    },
    "schema": {
      "const": "adeu_procedural_depth_benchmark_validation_report@1",
      "default": "adeu_procedural_depth_benchmark_validation_report@1",
      "title": "Schema",
      "type": "string"
    },
    "validation_case_results": {
      "items": {
        "$ref": "#/$defs/ProceduralDepthBenchmarkValidationCaseResult"
      },
      "minItems": 1,
      "title": "Validation Case Results",
      "type": "array"
    }
  },
  "required": [
    "procedural_depth_benchmark_validation_report_id",
    "evaluation_context_posture",
    "replay_count",
    "deterministic_replay_confirmed",
    "validation_case_results",
    "limitations"
  ],
  "title": "ProceduralDepthBenchmarkValidationReport",
  "type": "object"
}
