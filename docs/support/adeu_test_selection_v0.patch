+@dataclass(frozen=True)
+class OwnerInfo:
+    owner_key: str
+    owner_kind: Literal["package", "app"]
+    distribution_name: str | None
+    import_roots: tuple[str, ...] = ()
+    src_root: str | None = None
+    tests_root: str | None = None
+    pyproject_path: str | None = None
+    scripts_root: str | None = None
+    direct_local_dependency_owners: tuple[str, ...] = ()
+    reverse_local_dependency_owners: tuple[str, ...] = ()
+
+
+@dataclass
+class SelectorIndex:
+    repo_root: Path
+    owners: dict[str, OwnerInfo]
+    all_test_paths: list[str]
+    tests_by_owner: dict[str, list[str]]
+    module_to_source_path: dict[str, str]
+    source_path_to_module: dict[str, str]
+    module_to_owner: dict[str, str]
+    reverse_source_imports: dict[str, set[str]]
+    test_imported_modules: dict[str, set[str]]
+    test_literal_paths: dict[str, set[str]]
+    test_parse_errors: dict[str, str]
+    source_parse_errors: dict[str, str]
