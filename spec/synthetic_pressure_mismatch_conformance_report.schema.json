          "title": "Canonical Local Subject Only",
          "type": "boolean"
        },
        "count_based_aggregation_only": {
          "const": true,
          "default": true,
          "title": "Count Based Aggregation Only",
          "type": "boolean"
        },
        "evaluator_id": {
          "const": "adeu_core_ir.synthetic_pressure_mismatch_observation.derive_v39c_conformance_report@1",
