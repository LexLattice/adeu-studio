.DS_Store

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
dist/
build/
*.egg-info/

# Node / Next
node_modules/
.next/
out/
apps/api/var/

# Artifacts policy:
# - Keep deterministic versioned closeout artifacts in git.
# - Ignore transient/manual/generated-by-default artifacts unless explicitly whitelisted.
artifacts/*
!artifacts/.gitkeep
!artifacts/quality_dashboard_v*_closeout*.json
!artifacts/semantic_compiler/
artifacts/semantic_compiler/*
!artifacts/semantic_compiler/v41/
artifacts/semantic_compiler/v41/*
!artifacts/semantic_compiler/v41/surface_snapshot.json
!artifacts/semantic_compiler/v41/surface_diff.json
!artifacts/semantic_compiler/v41/evidence_manifest.json
!artifacts/stop_gate/
artifacts/stop_gate/*
!artifacts/stop_gate/metrics_v*_closeout*.json
!artifacts/stop_gate/report_v*_closeout*.md

# Editors
.idea/
.vscode/
