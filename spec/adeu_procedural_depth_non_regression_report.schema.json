    "procedural_depth_non_regression_report_id": {
      "title": "Procedural Depth Non Regression Report Id",
      "type": "string"
    },
    "regression_detected": {
      "title": "Regression Detected",
      "type": "boolean"
    },
    "replay_count": {
      "minimum": 1,
