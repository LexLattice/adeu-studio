+def compute_history_ledger_entry_id(
+    *,
+    source_id: str,
+    preclassification_id: str,
+    order_index: int,
+    entry_text_hash: str,
+) -> str:
+    digest = sha256_canonical_json(
+        {
+            "source_id": source_id,
+            "preclassification_id": preclassification_id,
+            "order_index": order_index,
+            "entry_text_hash": entry_text_hash,
+        }
+    )
+    return f"history_ledger_entry:{digest[:16]}"
+
+
+def compute_history_ledger_id(*, source_id: str, entry_ids: list[str]) -> str:
+    digest = sha256_canonical_json(
+        {
+            "source_id": source_id,
+            "entry_ids": entry_ids,
+        }
+    )
+    return f"history_ledger:{digest[:16]}"
+
+
+def compute_history_slice_id(
+    *,
+    source_id: str,
+    slice_index: int,
+    entry_ids: list[str],
+    chronology_start_order_index: int,
+    chronology_end_order_index: int,
+    theme_terms: list[str],
+) -> str:
+    digest = sha256_canonical_json(
+        {
+            "source_id": source_id,
+            "slice_index": slice_index,
+            "entry_ids": entry_ids,
+            "chronology_start_order_index": chronology_start_order_index,
+            "chronology_end_order_index": chronology_end_order_index,
+            "theme_terms": theme_terms,
+        }
+    )
+    return f"history_slice:{digest[:16]}"
+
+
+def compute_history_theme_anchor_id(
+    *,
+    source_id: str,
+    theme_key: str,
+    slice_ids: list[str],
+) -> str:
+    digest = sha256_canonical_json(
+        {
+            "source_id": source_id,
+            "theme_key": theme_key,
+            "slice_ids": slice_ids,
+        }
+    )
+    return f"history_theme_anchor:{digest[:16]}"
+
