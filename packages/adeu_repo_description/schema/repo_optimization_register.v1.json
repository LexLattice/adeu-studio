{
  "$defs": {
    "RepoDescriptionEvidenceRef": {
      "additionalProperties": false,
      "properties": {
        "evidence_kind": {
          "enum": [
            "observed_anchor_tuple_evidence",
            "structural_signature_evidence",
            "semantic_function_cue_evidence",
            "governance_cue_evidence",
            "lexical_cue_evidence",
            "adjudication_artifact_evidence",
            "reconstruction_subset_evidence",
            "planning_table_row_evidence",
            "planning_selection_evidence",
            "lock_contract_evidence",
            "dependency_policy_evidence"
          ],
          "title": "Evidence Kind",
          "type": "string"
        },
        "evidence_ref": {
          "title": "Evidence Ref",
          "type": "string"
        }
      },
      "required": [
        "evidence_ref",
        "evidence_kind"
      ],
      "title": "RepoDescriptionEvidenceRef",
      "type": "object"
    },
    "RepoOptimizationClusterMemberRef": {
      "additionalProperties": false,
      "properties": {
        "member_ref": {
          "title": "Member Ref",
          "type": "string"
        },
        "member_ref_kind": {
          "enum": [
            "file_surface",
            "module_surface",
            "schema_surface",
            "test_surface"
          ],
          "title": "Member Ref Kind",
          "type": "string"
        }
      },
      "required": [
        "member_ref_kind",
        "member_ref"
      ],
      "title": "RepoOptimizationClusterMemberRef",
      "type": "object"
    },
    "RepoOptimizationEntry": {
      "additionalProperties": false,
      "properties": {
        "amendment_entitlement": {
          "const": "not_authorized_by_this_artifact",
          "title": "Amendment Entitlement",
          "type": "string"
        },
        "compression_axis": {
          "enum": [
            "structural_compression",
            "semantic_compression",
            "governance_compression",
            "surface_compression"
          ],
          "title": "Compression Axis",
          "type": "string"
        },
        "derivation_method": {
          "enum": [
            "descriptive_projection",
            "bounded_signal_rule",
            "cross_artifact_join",
            "adjudicated_policy"
          ],
          "title": "Derivation Method",
          "type": "string"
        },
        "derivation_posture": {
          "enum": [
            "observed",
            "derived_deterministically",
            "inferred_heuristically",
            "adjudicated",
            "settled"
          ],
          "title": "Derivation Posture",
          "type": "string"
        },
        "descriptive_finding_summary": {
          "title": "Descriptive Finding Summary",
          "type": "string"
        },
        "entry_id": {
          "title": "Entry Id",
          "type": "string"
        },
        "finding_scope": {
          "$ref": "#/$defs/RepoOptimizationFindingScope"
        },
        "optimization_candidate_summary": {
          "title": "Optimization Candidate Summary",
          "type": "string"
        },
        "optimization_posture": {
          "enum": [
            "hotspot",
            "consolidation_candidate",
            "justified_monolith",
            "temporary_concentration",
            "forbidden_drift_zone"
          ],
          "title": "Optimization Posture",
          "type": "string"
        },
        "priority_posture": {
          "enum": [
            "informational_only",
            "planning_candidate",
            "adjudication_required"
          ],
          "title": "Priority Posture",
          "type": "string"
        },
        "secondary_compression_axes": {
          "items": {
            "enum": [
              "structural_compression",
              "semantic_compression",
              "governance_compression",
              "surface_compression"
            ],
            "type": "string"
          },
          "title": "Secondary Compression Axes",
          "type": "array"
        },
        "secondary_support_basis_tags": {
          "items": {
            "enum": [
              "duplicate_abstraction_signal",
              "repeated_law_expression",
              "cross_surface_invariant_restated",
              "long_file_or_concentrated_surface",
              "test_and_dependency_concentration"
            ],
            "type": "string"
          },
          "title": "Secondary Support Basis Tags",
          "type": "array"
        },
        "source_artifact_refs": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Source Artifact Refs",
          "type": "array"
        },
        "support_basis": {
          "enum": [
            "duplicate_abstraction_signal",
            "repeated_law_expression",
            "cross_surface_invariant_restated",
            "long_file_or_concentrated_surface",
            "test_and_dependency_concentration"
          ],
          "title": "Support Basis",
          "type": "string"
        },
        "supporting_evidence_refs": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Supporting Evidence Refs",
          "type": "array"
        }
      },
      "required": [
        "entry_id",
        "finding_scope",
        "compression_axis",
        "optimization_posture",
        "support_basis",
        "descriptive_finding_summary",
        "optimization_candidate_summary",
        "priority_posture",
        "amendment_entitlement",
        "derivation_posture",
        "derivation_method",
        "source_artifact_refs",
        "supporting_evidence_refs"
      ],
      "title": "RepoOptimizationEntry",
      "type": "object"
    },
    "RepoOptimizationFindingScope": {
      "additionalProperties": false,
      "properties": {
        "cluster_member_refs": {
          "items": {
            "$ref": "#/$defs/RepoOptimizationClusterMemberRef"
          },
          "title": "Cluster Member Refs",
          "type": "array"
        },
        "finding_scope_kind": {
          "enum": [
            "file_surface",
            "module_surface",
            "schema_surface",
            "test_surface",
            "cross_surface_cluster"
          ],
          "title": "Finding Scope Kind",
          "type": "string"
        },
        "finding_scope_ref": {
          "title": "Finding Scope Ref",
          "type": "string"
        }
      },
      "required": [
        "finding_scope_kind",
        "finding_scope_ref"
      ],
      "title": "RepoOptimizationFindingScope",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "bound_dependency_graph_ref": {
      "title": "Bound Dependency Graph Ref",
      "type": "string"
    },
    "bound_entity_catalog_ref": {
      "title": "Bound Entity Catalog Ref",
      "type": "string"
    },
    "bound_schema_family_registry_ref": {
      "title": "Bound Schema Family Registry Ref",
      "type": "string"
    },
    "bound_symbol_catalog_ref": {
      "title": "Bound Symbol Catalog Ref",
      "type": "string"
    },
    "bound_test_intent_matrix_ref": {
      "title": "Bound Test Intent Matrix Ref",
      "type": "string"
    },
    "evidence_refs": {
      "items": {
        "$ref": "#/$defs/RepoDescriptionEvidenceRef"
      },
      "minItems": 1,
      "title": "Evidence Refs",
      "type": "array"
    },
    "extraction_method": {
      "enum": [
        "descriptive_projection",
        "bounded_signal_rule",
        "cross_artifact_join",
        "adjudicated_policy"
      ],
      "title": "Extraction Method",
      "type": "string"
    },
    "extraction_posture": {
      "enum": [
        "observed",
        "derived_deterministically",
        "inferred_heuristically",
        "adjudicated",
        "settled"
      ],
      "title": "Extraction Posture",
      "type": "string"
    },
    "optimization_entries": {
      "items": {
        "$ref": "#/$defs/RepoOptimizationEntry"
      },
      "minItems": 1,
      "title": "Optimization Entries",
      "type": "array"
    },
    "register_scope": {
      "title": "Register Scope",
      "type": "string"
    },
    "repo_optimization_register_id": {
      "title": "Repo Optimization Register Id",
      "type": "string"
    },
    "repo_snapshot_hash": {
      "title": "Repo Snapshot Hash",
      "type": "string"
    },
    "repo_snapshot_id": {
      "title": "Repo Snapshot Id",
      "type": "string"
    },
    "schema": {
      "const": "repo_optimization_register@1",
      "default": "repo_optimization_register@1",
      "title": "Schema",
      "type": "string"
    },
    "snapshot_validity_posture": {
      "enum": [
        "snapshot_bound_current",
        "snapshot_bound_historical"
      ],
      "title": "Snapshot Validity Posture",
      "type": "string"
    },
    "source_set": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Source Set",
      "type": "array"
    },
    "source_set_hash": {
      "title": "Source Set Hash",
      "type": "string"
    }
  },
  "required": [
    "repo_optimization_register_id",
    "repo_snapshot_id",
    "repo_snapshot_hash",
    "snapshot_validity_posture",
    "source_set",
    "source_set_hash",
    "bound_entity_catalog_ref",
    "bound_schema_family_registry_ref",
    "bound_symbol_catalog_ref",
    "bound_dependency_graph_ref",
    "bound_test_intent_matrix_ref",
    "register_scope",
    "extraction_posture",
    "extraction_method",
    "optimization_entries",
    "evidence_refs"
  ],
  "title": "RepoOptimizationRegister",
  "type": "object"
}
