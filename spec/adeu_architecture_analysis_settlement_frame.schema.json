    "ActiveEscalationRecord": {
      "additionalProperties": false,
      "properties": {
        "supporting_refs": {
          "items": {
            "type": "string"
          },
          "title": "Supporting Refs",
          "type": "array"
        },
        "trigger_id": {
          "enum": [
            "unresolved_high_impact_ambiguity",
            "silent_semantic_assumption_needed",
            "impossibility_claim_without_proof",
            "externalized_search_or_check_required"
          ],
          "title": "Trigger Id",
          "type": "string"
        }
      },
      "required": [
        "trigger_id",
        "supporting_refs"
      ],
      "title": "ActiveEscalationRecord",
      "type": "object"
    },
    "AffordanceDecisionEntry": {
      "additionalProperties": false,
      "properties": {
        "decision_class": {
          "enum": [
            "used",
            "deferred",
            "intentionally_declined"
          ],
          "title": "Decision Class",
          "type": "string"
        },
        "decision_id": {
          "title": "Decision Id",
          "type": "string"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "target_ref": {
          "title": "Target Ref",
          "type": "string"
        }
      },
      "required": [
        "decision_id",
        "target_ref",
        "decision_class",
        "rationale"
      ],
      "title": "AffordanceDecisionEntry",
      "type": "object"
