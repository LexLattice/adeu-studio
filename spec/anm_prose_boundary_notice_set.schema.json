            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Consumed V66B Reader Projection Manifest Ref Or None"
        },
        "consumed_v66b_semantic_diff_report_hash_or_none": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Consumed V66B Semantic Diff Report Hash Or None"
        },
        "consumed_v66b_semantic_diff_report_ref_or_none": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Consumed V66B Semantic Diff Report Ref Or None"
        }
      },
      "required": [
        "consumed_v66a_source_set_manifest_ref",
        "consumed_v66a_source_set_manifest_hash",
        "consumed_v66a_authority_profile_set_ref_or_hash",
        "consumed_v66a_doc_class_policy_ref",
        "consumed_v66a_doc_class_policy_hash",
        "consumed_v66b_migration_binding_profile_ref",
        "consumed_v66b_migration_binding_profile_hash"
      ],
      "title": "AnmV66CConsumedLineage",
      "type": "object"
    },
    "AnmV66CPolicyAnchor": {
      "additionalProperties": false,
      "properties": {
        "advisory_outcome_reducer_hash": {
          "minLength": 1,
          "title": "Advisory Outcome Reducer Hash",
          "type": "string"
        },
        "advisory_outcome_reducer_ref": {
          "minLength": 1,
          "title": "Advisory Outcome Reducer Ref",
          "type": "string"
        },
        "notice_detection_policy_hash": {
          "minLength": 1,
          "title": "Notice Detection Policy Hash",
          "type": "string"
        },
        "notice_detection_policy_ref": {
          "minLength": 1,
          "title": "Notice Detection Policy Ref",
          "type": "string"
        },
        "policy_anchor_hash": {
          "minLength": 1,
          "title": "Policy Anchor Hash",
          "type": "string"
        },
        "policy_anchor_ref": {
          "minLength": 1,
          "title": "Policy Anchor Ref",
          "type": "string"
        },
        "policy_anchor_schema_id": {
          "minLength": 1,
          "title": "Policy Anchor Schema Id",
          "type": "string"
        }
      },
      "required": [
        "policy_anchor_ref",
        "policy_anchor_hash",
        "policy_anchor_schema_id",
        "advisory_outcome_reducer_ref",
        "advisory_outcome_reducer_hash",
        "notice_detection_policy_ref",
        "notice_detection_policy_hash"
      ],
      "title": "AnmV66CPolicyAnchor",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "consumed_lineage": {
      "$ref": "#/$defs/AnmV66CConsumedLineage"
    },
    "notice_rows": {
      "items": {
        "$ref": "#/$defs/AnmProseBoundaryNoticeRow"
      },
      "title": "Notice Rows",
      "type": "array"
    },
    "notice_set_id": {
      "minLength": 1,
      "title": "Notice Set Id",
      "type": "string"
    },
    "policy_anchor": {
      "$ref": "#/$defs/AnmV66CPolicyAnchor"
    },
    "report_status": {
      "enum": [
        "valid",
        "invalid_missing_prior_basis",
        "invalid_prior_basis_hash_mismatch",
        "invalid_policy_anchor",
        "invalid_unsupported_schema",
        "invalid_notice_evidence",
        "invalid_authority_claim_rejected"
      ],
      "title": "Report Status",
      "type": "string"
    },
    "schema_id": {
      "const": "anm_prose_boundary_notice_set@1",
      "default": "anm_prose_boundary_notice_set@1",
      "title": "Schema Id",
      "type": "string"
    }
  },
  "required": [
    "notice_set_id",
    "report_status",
    "consumed_lineage",
    "policy_anchor"
  ],
  "title": "AnmProseBoundaryNoticeSet",
  "type": "object"
}
