+SCHEMA = "repo_test_selection_plan@2"
+SELECTOR_VERSION = "dependency_witness_selector_v0_2"
+DEFAULT_INTENT_MATRIX_PATH = (
+    "apps/api/fixtures/repo_description/vnext_plus103/"
+    "repo_test_intent_matrix_v103_reference.json"
+)
+ROOT_ESCALATION_PATHS = {"pyproject.toml", "Makefile"}
