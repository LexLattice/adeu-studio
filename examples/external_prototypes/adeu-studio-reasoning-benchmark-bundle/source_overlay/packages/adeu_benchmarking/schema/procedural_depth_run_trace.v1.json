{
  "$defs": {
    "ProceduralDepthTraceEvent": {
      "additionalProperties": false,
      "properties": {
        "event_index": {
          "minimum": 0,
          "title": "Event Index",
          "type": "integer"
        },
        "event_type": {
          "enum": [
            "activate",
            "complete",
            "return"
          ],
          "title": "Event Type",
          "type": "string"
        },
        "step_id": {
          "title": "Step Id",
          "type": "string"
        },
        "target_step_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Step Id"
        }
      },
      "required": [
        "event_index",
        "event_type",
        "step_id"
      ],
      "title": "ProceduralDepthTraceEvent",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "benchmark_execution_context_ref": {
      "title": "Benchmark Execution Context Ref",
      "type": "string"
    },
    "observed_events": {
      "items": {
        "$ref": "#/$defs/ProceduralDepthTraceEvent"
      },
      "minItems": 1,
      "title": "Observed Events",
      "type": "array"
    },
    "observed_final_output_summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Observed Final Output Summary"
    },
    "procedural_depth_instance_ref": {
      "title": "Procedural Depth Instance Ref",
      "type": "string"
    },
    "procedural_depth_run_trace_id": {
      "title": "Procedural Depth Run Trace Id",
      "type": "string"
    },
    "run_label": {
      "title": "Run Label",
      "type": "string"
    },
    "schema": {
      "const": "procedural_depth_run_trace@1",
      "default": "procedural_depth_run_trace@1",
      "title": "Schema",
      "type": "string"
    },
    "trace_notes": {
      "items": {
        "type": "string"
      },
      "title": "Trace Notes",
      "type": "array"
    }
  },
  "required": [
    "procedural_depth_run_trace_id",
    "procedural_depth_instance_ref",
    "benchmark_execution_context_ref",
    "run_label",
    "observed_events"
  ],
  "title": "ProceduralDepthRunTrace",
  "type": "object"
}
