      "title": "Schema",
      "type": "string"
    },
    "suite_hash": {
      "title": "Suite Hash",
      "type": "string"
    },
    "suite_id": {
      "title": "Suite Id",
      "type": "string"
    },
    "suite_label": {
      "title": "Suite Label",
      "type": "string"
    },
    "suite_members": {
      "items": {
        "$ref": "#/$defs/ReasoningProbeSuiteMember"
      },
      "minItems": 6,
      "title": "Suite Members",
      "type": "array"
    },
    "template_classes_included": {
      "items": {
        "enum": [
          "lane_preserving_decomposition",
          "branching_under_uncertainty",
          "local_repair_continuation",
          "invariance_under_surface_variation"
        ],
        "type": "string"
      },
      "maxItems": 4,
      "minItems": 4,
      "title": "Template Classes Included",
      "type": "array"
    }
  },
  "required": [
    "suite_id",
    "suite_label",
    "suite_members",
    "template_classes_included",
    "accepted_surface_variation_kinds",
    "repair_locality_posture",
    "suite_hash"
  ],
  "title": "ReasoningProbeSuite",
  "type": "object"
}
