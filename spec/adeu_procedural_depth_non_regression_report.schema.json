      "type": "object"
    },
    "ProceduralDepthSupportingMetricRef": {
      "additionalProperties": false,
      "properties": {
        "metric_ref": {
          "title": "Metric Ref",
          "type": "string"
        },
        "replay_index": {
          "minimum": 0,
          "title": "Replay Index",
          "type": "integer"
        }
      },
      "required": [
        "replay_index",
        "metric_ref"
      ],
      "title": "ProceduralDepthSupportingMetricRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "baseline_instance_ref": {
      "title": "Baseline Instance Ref",
      "type": "string"
    },
