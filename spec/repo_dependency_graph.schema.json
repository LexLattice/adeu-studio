{
  "$defs": {
    "RepoDependencyGraphEdge": {
      "additionalProperties": false,
      "properties": {
        "dependency_kind": {
          "enum": [
            "module_import",
            "symbol_reference",
            "inheritance"
          ],
          "title": "Dependency Kind",
          "type": "string"
        },
        "dependency_posture": {
          "enum": [
            "internal_resolved",
            "boundary_external",
            "boundary_out_of_scope"
          ],
          "title": "Dependency Posture",
          "type": "string"
        },
        "derivation_method": {
          "enum": [
            "ast_parse",
            "deterministic_projection",
            "bounded_inference_rule",
            "adjudicated_policy"
          ],
          "title": "Derivation Method",
          "type": "string"
        },
        "derivation_posture": {
          "enum": [
            "observed",
            "derived_deterministically",
            "inferred_heuristically",
            "adjudicated",
            "settled"
          ],
          "title": "Derivation Posture",
          "type": "string"
        },
        "edge_id": {
          "title": "Edge Id",
          "type": "string"
        },
        "from_ref": {
          "title": "From Ref",
          "type": "string"
        },
        "from_ref_kind": {
          "enum": [
            "internal_symbol",
            "internal_module_boundary",
            "external_dependency"
          ],
          "title": "From Ref Kind",
          "type": "string"
        },
        "source_artifact_refs": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Source Artifact Refs",
          "type": "array"
        },
        "supporting_evidence_refs": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Supporting Evidence Refs",
          "type": "array"
        },
        "to_ref": {
          "title": "To Ref",
          "type": "string"
        },
        "to_ref_kind": {
          "enum": [
            "internal_symbol",
            "internal_module_boundary",
            "external_dependency"
          ],
          "title": "To Ref Kind",
          "type": "string"
        }
      },
      "required": [
        "edge_id",
        "from_ref_kind",
        "from_ref",
        "to_ref_kind",
        "to_ref",
        "dependency_kind",
        "dependency_posture",
        "derivation_posture",
        "derivation_method",
        "source_artifact_refs",
        "supporting_evidence_refs"
      ],
      "title": "RepoDependencyGraphEdge",
      "type": "object"
    },
    "RepoDescriptionEvidenceRef": {
      "additionalProperties": false,
      "properties": {
        "evidence_kind": {
          "enum": [
            "observed_anchor_tuple_evidence",
            "structural_signature_evidence",
            "semantic_function_cue_evidence",
            "governance_cue_evidence",
            "lexical_cue_evidence",
            "adjudication_artifact_evidence",
            "reconstruction_subset_evidence",
            "planning_table_row_evidence",
            "planning_selection_evidence",
            "lock_contract_evidence",
            "dependency_policy_evidence"
          ],
          "title": "Evidence Kind",
          "type": "string"
        },
        "evidence_ref": {
          "title": "Evidence Ref",
          "type": "string"
        }
      },
      "required": [
        "evidence_ref",
        "evidence_kind"
      ],
      "title": "RepoDescriptionEvidenceRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "dependency_edges": {
      "items": {
        "$ref": "#/$defs/RepoDependencyGraphEdge"
      },
      "title": "Dependency Edges",
      "type": "array"
    },
    "evidence_refs": {
      "items": {
        "$ref": "#/$defs/RepoDescriptionEvidenceRef"
      },
      "minItems": 1,
      "title": "Evidence Refs",
      "type": "array"
    },
    "extraction_method": {
      "enum": [
        "ast_parse",
        "deterministic_projection",
        "bounded_inference_rule",
        "adjudicated_policy"
      ],
      "title": "Extraction Method",
      "type": "string"
    },
    "extraction_posture": {
      "enum": [
        "observed",
        "derived_deterministically",
        "inferred_heuristically",
        "adjudicated",
        "settled"
      ],
      "title": "Extraction Posture",
      "type": "string"
    },
    "graph_scope": {
      "title": "Graph Scope",
      "type": "string"
    },
    "repo_dependency_graph_id": {
      "title": "Repo Dependency Graph Id",
      "type": "string"
    },
    "repo_snapshot_hash": {
      "title": "Repo Snapshot Hash",
      "type": "string"
    },
    "repo_snapshot_id": {
      "title": "Repo Snapshot Id",
      "type": "string"
    },
    "schema": {
      "const": "repo_dependency_graph@1",
      "default": "repo_dependency_graph@1",
      "title": "Schema",
      "type": "string"
    },
    "snapshot_validity_posture": {
      "enum": [
        "snapshot_bound_current",
        "snapshot_bound_historical"
      ],
      "title": "Snapshot Validity Posture",
      "type": "string"
    },
    "source_set": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Source Set",
      "type": "array"
    },
    "source_set_hash": {
      "title": "Source Set Hash",
      "type": "string"
    }
  },
  "required": [
    "repo_dependency_graph_id",
    "repo_snapshot_id",
    "repo_snapshot_hash",
    "snapshot_validity_posture",
    "source_set",
    "source_set_hash",
    "graph_scope",
    "extraction_posture",
    "extraction_method",
    "evidence_refs"
  ],
  "title": "RepoDependencyGraph",
  "type": "object"
}
