{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": [
      "ES2023",
      "DOM"
    ],
    "types": [
      "node",
      "electron"
    ]
  },
  "include": [
    "scripts/**/*.mjs",
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}
