{
  "$defs": {
    "MetaAuthoritativeInputRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_ref": {
          "minLength": 1,
          "title": "Artifact Ref",
          "type": "string"
        },
        "artifact_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Artifact Sha256",
          "type": "string"
        },
        "input_id": {
          "enum": [
            "v65_assessment_doc",
            "v65_closeout_decision_doc",
            "v65_lock_doc",
            "v65_metric_key_continuity_assertion",
            "v65_quality_dashboard_artifact",
            "v65_runtime_observability_comparison",
            "v65_stop_gate_metrics_artifact",
            "v65_stop_gate_report_artifact",
            "v65_v36e_evidence"
          ],
          "title": "Input Id",
          "type": "string"
        }
      },
      "required": [
        "input_id",
        "artifact_ref",
        "artifact_sha256"
      ],
      "title": "MetaAuthoritativeInputRef",
      "type": "object"
    },
    "MetaReferenceLoopAnchor": {
      "additionalProperties": false,
      "properties": {
        "reference_arc": {
          "minimum": 1,
          "title": "Reference Arc",
          "type": "integer"
        },
        "reference_phase": {
          "const": "closeout",
          "default": "closeout",
          "title": "Reference Phase",
          "type": "string"
        },
        "shape": {
          "const": "arc_closeout_bundle_instance",
          "default": "arc_closeout_bundle_instance",
          "title": "Shape",
          "type": "string"
        }
      },
      "required": [
        "reference_arc"
      ],
      "title": "MetaReferenceLoopAnchor",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "adeu_priority_order": {
      "items": {
        "enum": [
          "deontics",
          "epistemics",
          "ontology",
          "utility"
        ],
        "type": "string"
      },
      "title": "Adeu Priority Order",
      "type": "array"
    },
    "allowed_reasoning_latitude": {
      "items": {
        "enum": [
          "classify_drift_hypotheses",
          "compare_expected_and_observed_checkpoint_shape",
          "propose_narrow_repairs",
          "summarize_uncompiled_discrepancy"
        ],
        "type": "string"
      },
      "title": "Allowed Reasoning Latitude",
      "type": "array"
    },
    "authoritative_inputs": {
      "items": {
        "$ref": "#/$defs/MetaAuthoritativeInputRef"
      },
      "title": "Authoritative Inputs",
      "type": "array"
    },
    "failure_condition": {
      "minLength": 1,
      "title": "Failure Condition",
      "type": "string"
    },
    "hard_checkpoint_truth_boundary_preserved": {
      "const": true,
      "default": true,
      "title": "Hard Checkpoint Truth Boundary Preserved",
      "type": "boolean"
    },
    "intent_packet_id": {
      "minLength": 1,
      "title": "Intent Packet Id",
      "type": "string"
    },
    "objective": {
      "minLength": 1,
      "title": "Objective",
      "type": "string"
    },
    "operational_influence_distinct_from_accepted_compilation": {
      "const": true,
      "default": true,
      "title": "Operational Influence Distinct From Accepted Compilation",
      "type": "boolean"
    },
    "reference_anchor": {
      "$ref": "#/$defs/MetaReferenceLoopAnchor"
    },
    "reference_instance_id": {
      "minLength": 1,
      "title": "Reference Instance Id",
      "type": "string"
    },
    "reference_loop_family": {
      "const": "arc_bundle_recursive_compilation_loop",
      "default": "arc_bundle_recursive_compilation_loop",
      "title": "Reference Loop Family",
      "type": "string"
    },
    "refusal_escalation_conditions": {
      "items": {
        "enum": [
          "attempted_checkpoint_truth_substitution_by_prose",
          "authoritative_input_ref_unresolved",
          "hard_checkpoint_claim_without_bound_executor",
          "out_of_scope_runnable_loop_request"
        ],
        "type": "string"
      },
      "title": "Refusal Escalation Conditions",
      "type": "array"
    },
    "required_evidence_outputs": {
      "items": {
        "enum": [
          "metric_key_continuity_assertion@1",
          "quality_dashboard_json",
          "runtime_observability_comparison@1",
          "stop_gate_metrics@1",
          "stop_gate_report_markdown",
          "v37a_meta_intent_module_catalog_evidence@1"
        ],
        "type": "string"
      },
      "title": "Required Evidence Outputs",
      "type": "array"
    },
    "required_hard_checkpoints": {
      "items": {
        "enum": [
          "artifact_consistency_lint",
          "bundle_lint",
          "committed_event_stream_validation",
          "instruction_policy_validation",
          "quality_dashboard_build",
          "semantic_closeout_lint",
          "stop_gate_metrics_build"
        ],
        "type": "string"
      },
      "title": "Required Hard Checkpoints",
      "type": "array"
    },
    "schema": {
      "const": "meta_testing_intent_packet@1",
      "default": "meta_testing_intent_packet@1",
      "title": "Schema",
      "type": "string"
    },
    "success_condition": {
      "minLength": 1,
      "title": "Success Condition",
      "type": "string"
    }
  },
  "required": [
    "reference_instance_id",
    "intent_packet_id",
    "reference_anchor",
    "objective",
    "success_condition",
    "failure_condition",
    "authoritative_inputs",
    "required_hard_checkpoints",
    "required_evidence_outputs",
    "allowed_reasoning_latitude",
    "refusal_escalation_conditions",
    "adeu_priority_order"
  ],
  "title": "MetaTestingIntentPacket",
  "type": "object"
}
