              "checkpoint_class"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "oracle_request_id"
                  ]
                },
                {
                  "required": [
                    "oracle_resolution_id"
                  ]
                }
              ]
            },
            "properties": {
              "final_adjudication": {
                "const": "resolved_pass"
              }
            }
          }
