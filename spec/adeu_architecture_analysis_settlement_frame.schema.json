            "type": "string"
          },
          "title": "Trigger Ids",
          "type": "array"
        }
      },
      "required": [
        "trigger_ids"
      ],
      "title": "EscalationTriggerPolicy",
      "type": "object"
    },
    "InterpretationEntry": {
      "additionalProperties": false,
      "properties": {
        "interpretation_id": {
          "title": "Interpretation Id",
          "type": "string"
        },
        "linked_ambiguity_refs": {
          "items": {
            "type": "string"
          },
          "title": "Linked Ambiguity Refs",
          "type": "array"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "support_refs": {
          "items": {
            "type": "string"
          },
          "title": "Support Refs",
          "type": "array"
        }
      },
      "required": [
        "interpretation_id",
        "summary",
        "support_refs"
      ],
      "title": "InterpretationEntry",
      "type": "object"
    }
