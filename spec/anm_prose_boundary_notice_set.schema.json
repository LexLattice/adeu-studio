{
  "$defs": {
    "AnmProseBoundaryNoticeRow": {
      "additionalProperties": false,
      "properties": {
        "advisory_effect": {
          "enum": [
            "none",
            "review_visibility_only",
            "registration_review_needed",
            "projection_refresh_needed",
            "transition_law_review_needed",
            "markdown_transition_candidate"
          ],
          "title": "Advisory Effect",
          "type": "string"
        },
        "authority_effect": {
          "enum": [
            "no_authority_minted",
            "current_markdown_remains_controlling",
            "invalid_authority_claim_rejected"
          ],
          "title": "Authority Effect",
          "type": "string"
        },
        "compiled_authority_block_ref_or_none": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Compiled Authority Block Ref Or None"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array",
          "uniqueItems": true
        },
        "notice_id": {
          "minLength": 1,
          "title": "Notice Id",
          "type": "string"
        },
        "notice_kind": {
          "enum": [
            "normative_tone_without_compiled_authority_block",
            "projection_staleness_visible",
            "generated_projection_authority_overread_risk",
            "transition_law_scope_ambiguity",
            "class_policy_overpromotion_risk"
          ],
          "title": "Notice Kind",
          "type": "string"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error"
          ],
          "title": "Severity",
          "type": "string"
        },
        "source_doc_ref": {
          "minLength": 1,
          "title": "Source Doc Ref",
          "type": "string"
        },
        "subject_ref": {
          "minLength": 1,
          "title": "Subject Ref",
          "type": "string"
        }
      },
      "required": [
        "notice_id",
        "notice_kind",
        "severity",
        "source_doc_ref",
        "subject_ref",
        "advisory_effect",
        "authority_effect"
      ],
      "title": "AnmProseBoundaryNoticeRow",
      "type": "object"
    },
    "AnmV66CConsumedLineage": {
      "additionalProperties": false,
      "properties": {
        "consumed_v66a_authority_profile_set_ref_or_hash": {
