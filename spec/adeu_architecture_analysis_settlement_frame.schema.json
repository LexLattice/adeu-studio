    "EscalationTriggerPolicy": {
      "additionalProperties": false,
      "properties": {
        "trigger_ids": {
          "items": {
            "enum": [
              "unresolved_high_impact_ambiguity",
              "silent_semantic_assumption_needed",
              "impossibility_claim_without_proof",
              "externalized_search_or_check_required"
