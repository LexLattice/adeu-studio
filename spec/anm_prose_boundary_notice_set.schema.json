          "type": "string"
        },
        "consumed_v66a_doc_class_policy_ref": {
          "minLength": 1,
          "title": "Consumed V66A Doc Class Policy Ref",
          "type": "string"
        },
        "consumed_v66a_source_set_manifest_hash": {
          "minLength": 1,
          "title": "Consumed V66A Source Set Manifest Hash",
          "type": "string"
        },
        "consumed_v66a_source_set_manifest_ref": {
          "minLength": 1,
          "title": "Consumed V66A Source Set Manifest Ref",
          "type": "string"
        },
        "consumed_v66b_migration_binding_profile_hash": {
          "minLength": 1,
          "title": "Consumed V66B Migration Binding Profile Hash",
          "type": "string"
        },
        "consumed_v66b_migration_binding_profile_ref": {
          "minLength": 1,
          "title": "Consumed V66B Migration Binding Profile Ref",
          "type": "string"
        },
        "consumed_v66b_reader_projection_manifest_hash_or_none": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Consumed V66B Reader Projection Manifest Hash Or None"
        },
        "consumed_v66b_reader_projection_manifest_ref_or_none": {
          "anyOf": [
            {
              "type": "string"
